  "headings": [
    {
      "level": 3,
      "text": "Friday, March 13th"
    },
    {
      "level": 3,
      "text": "Aerial Yoga"
    },
    {
      "level": 4,
      "text": "Join Danielle for a fun and supportive aerial yoga class designed for all levels from first-timers to seasoned yogis."
    },
    {
      "level": 3,
      "text": "Saturday, March 14th"
    },
    {
      "level": 3,
      "text": "Inversion workshop"
    },
    {
      "level": 4,
      "text": "Join JoEllen for a fun workshop focused on building a safe, sustainable foundation for inversions. We’ll refine shoulder and core alignment while exploring headstand, forearm stand, and handstand variations."
    },
    {
      "level": 3,
      "text": "Saturday, March 14th"
    },
    {
      "level": 3,
      "text": "Gong experience with Sri Yantra"
    },
    {
      "level": 4,
      "text": "Join Sri Yantra for immersive gong and sound bowl vibrations that invite deep rest, release, and renewal."
    },
    {
      "level": 3,
      "text": "Sunday, March 29th"
    },
    {
      "level": 3,
      "text": "Yoga on the Patio @ Meribo"
    },
    {
      "level": 4,
      "text": "Join us for a donation based class and outdoor flow. All donations go to NAMI!"
    }
  ],
