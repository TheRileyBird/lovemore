---
import Button from './Button.astro';

interface Props {
	title: string;
	subtitle?: string;
	location?: string;
	image: string | null;
	body: string;
	gallery?: Array<{ url: string; alternativeText: string }>;
	startDate?: string;
	endDate?: string;
	date?: string;
	isPastEvent: boolean;
	ctaButtonLabel?: string;
	ctaButtonUrl?: string;
	backLink: string;
	backLinkText: string;
	price?: number;
}

const {
	title,
	subtitle,
	location,
	image,
	body,
	gallery = [],
	startDate,
	endDate,
	date,
	isPastEvent,
	ctaButtonLabel,
	ctaButtonUrl,
	backLink,
	backLinkText,
	price
} = Astro.props;

// Format dates for display
const formatDate = (dateStr: string) => {
	return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};

const dateDisplay = startDate && endDate
	? `${formatDate(startDate)} - ${formatDate(endDate)}`
	: startDate
		? formatDate(startDate)
		: endDate
			? formatDate(endDate)
			: date
				? formatDate(date)
				: '';
---

<!-- Content Section -->
<section class="py-20 bg-cream">
	<div class="container mx-auto px-6">
		<div class="max-w-6xl mx-auto">
			{/* Past Event Banner */}
			{isPastEvent && (
				<div class="mb-8 p-6 bg-neutral-100 border border-neutral-300 rounded-xl">
					<p class="text-neutral-700 text-center font-medium">
						⏰ This event has passed. Check out our <a href={backLink} class="text-brand hover:underline">{backLinkText}</a>.
					</p>
				</div>
			)}

			{/* Price Display */}
			{price && (
				<div class="mb-8 text-center">
					<div class="inline-flex items-center gap-3 px-6 py-4 bg-white border-2 border-brand rounded-2xl shadow-sm">
						<span class="text-neutral-600 font-medium text-lg">Investment:</span>
						<span class="text-3xl font-bold text-brand">${price}</span>
					</div>
				</div>
			)}

			<div class="grid grid-cols-1 lg:grid-cols-[350px_1fr] gap-8 mb-12">
				{image && (
					<div class="lg:sticky lg:top-24 h-fit">
						<img
							src={image}
							alt={title}
							class="w-full h-auto rounded-lg"
						/>
					</div>
				)}

				<div class="prose prose-lg max-w-none [&_p]:text-neutral-600 [&_p]:text-base [&_p]:leading-relaxed [&_p]:mb-4 [&_h2]:font-display [&_h2]:text-2xl [&_h2]:md:text-3xl [&_h2]:font-bold [&_h2]:text-brand [&_h2]:tracking-wide [&_h2]:mb-4 [&_h2]:mt-12 [&_h2:first-child]:mt-0 [&_h3]:font-display [&_h3]:text-xl [&_h3]:md:text-2xl [&_h3]:font-semibold [&_h3]:text-brand [&_h3]:tracking-wide [&_h3]:mb-3 [&_h3]:mt-10 [&_h3:first-child]:mt-0 [&_ul]:text-neutral-600 [&_ul]:text-base [&_ul]:mb-6 [&_ul]:list-disc [&_ul]:pl-6 [&_li]:mb-2 [&_strong]:text-charcoal [&_strong]:font-semibold" set:html={body} />
			</div>

			<!-- Buttons -->
			<div class="flex flex-col mb-12 sm:flex-row gap-4 justify-center">
				{ctaButtonLabel && ctaButtonUrl ? (
					<Button href={ctaButtonUrl} variant="primary" size="large">
						{ctaButtonLabel}
					</Button>
				) : (
					<Button href="/contact" variant="primary" size="large">
						Request More Information
					</Button>
				)}
				<a
					href={backLink}
					class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
				>
					{backLinkText}
				</a>
			</div>

			{/* Gallery Grid */}
			{gallery && gallery.length > 0 && (
				<div class={`grid gap-4 mb-12 ${
					gallery.length === 1 ? 'grid-cols-1 max-w-md mx-auto' :
					gallery.length === 2 ? 'grid-cols-1 md:grid-cols-2' :
					gallery.length === 3 ? 'grid-cols-1 md:grid-cols-3' :
					'grid-cols-2 md:grid-cols-4'
				}`}>
					{gallery.map((image: any) => (
						<div class="aspect-square overflow-hidden rounded-lg">
							<img
								src={image.url}
								alt={image.alternativeText}
								class="w-full h-full object-cover"
							/>
						</div>
					))}
				</div>
			)}
		</div>
	</div>
</section>
