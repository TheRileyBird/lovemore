---
interface Props {
	href?: string;
	type?: 'button' | 'submit' | 'reset';
	variant?: 'primary' | 'secondary' | 'outline';
	size?: 'default' | 'large' | 'small';
	class?: string;
}

const { href, type = 'button', variant = 'primary', size = 'default', class: className = '' } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center gap-2 font-medium tracking-luxury rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2';

const variantClasses = {
	primary: 'bg-brand text-white hover:bg-brand-dark shadow-sm hover:shadow-md hover:translate-y-[-1px]',
	secondary: 'bg-cream-200 text-charcoal hover:bg-beige-200 shadow-sm hover:shadow',
	outline: 'bg-transparent border-2 border-brand text-brand hover:bg-brand-pale'
};

const sizeClasses = {
	small: 'px-6 py-3 text-sm',
	default: 'px-8 py-5 text-base',
	large: 'px-12 py-6 text-lg'
};

const Element = href ? 'a' : 'button';
const elementProps = href ? { href } : { type };
---

<Element {...elementProps} class:list={[baseClasses, variantClasses[variant], sizeClasses[size], className]}>
	<slot />
</Element>
