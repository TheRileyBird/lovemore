---
interface Props {
	name: string;
	title: string;
	image: ImageMetadata;
	slug?: string;
}

const { name, title, image, slug } = Astro.props;
---

<div class="text-center">
	<div class="aspect-square overflow-hidden rounded-2xl mb-4 border border-warm-gray-200">
		<img
			src={image.src}
			alt={name}
			class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
			loading="lazy"
		/>
	</div>
	<h3 class="text-xl text-charcoal mb-1 font-sans">
		{name}
	</h3>
	<p class="text-sm text-neutral-600">{title}</p>
</div>
