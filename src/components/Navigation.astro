---
import logoImage from '../assets/images/logo.webp';
import Button from './Button.astro';
---

<nav
	x-data="{ scrolled: false }"
	@scroll.window="scrolled = window.pageYOffset > 50"
	:class="scrolled ? 'py-2' : 'py-4'"
	class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-warm-gray-200 shadow-sm transition-all duration-300"
	role="navigation"
	aria-label="Main navigation"
>
	<div class="container mx-auto px-6">
		<div class="flex xl:grid xl:grid-cols-3 items-center gap-8">
			<!-- Left: Navigation Links -->
			<div class="hidden xl:flex items-center gap-8 xl:col-span-1">
				<!-- Schedule Dropdown -->
				<div x-data="{ open: false }" class="relative">
					<button
						@mouseenter="open = true"
						@mouseleave="open = false"
						@keydown.escape="open = false"
						:aria-expanded="open"
						aria-haspopup="true"
						aria-controls="schedule-menu"
						class="flex items-center gap-1 text-xs font-medium text-neutral-600 hover:text-brand transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 rounded px-2 py-1 uppercase tracking-wider"
					>
						<span>Schedule</span>
						<svg class="w-3 h-3" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
						</svg>
					</button>
					<div
						x-show="open"
						@mouseenter="open = true"
						@mouseleave="open = false"
						x-transition:enter="transition ease-out duration-200"
						x-transition:enter-start="opacity-0 scale-95"
						x-transition:enter-end="opacity-100 scale-100"
						x-transition:leave="transition ease-in duration-150"
						x-transition:leave-start="opacity-100 scale-100"
						x-transition:leave-end="opacity-0 scale-95"
						id="schedule-menu"
						class="absolute left-0 mt-2 w-56 bg-white rounded-xl shadow-lg border border-warm-gray-200 py-2 z-50"
						style="display: none;"
					>
						<a href="/schedule" class="block px-4 py-2 text-sm text-neutral-700 hover:bg-cream-200 hover:text-brand transition-colors">Book a Class</a>
						<a href="/studio-classes" class="block px-4 py-2 text-sm text-neutral-700 hover:bg-cream-200 hover:text-brand transition-colors">Class Descriptions</a>
						<a href="/specialty-classes" class="block px-4 py-2 text-sm text-neutral-700 hover:bg-cream-200 hover:text-brand transition-colors">Specialty Events & Workshops</a>
						<a href="/virtual-studio" class="block px-4 py-2 text-sm text-neutral-700 hover:bg-cream-200 hover:text-brand transition-colors">Virtual Studio</a>
					</div>
				</div>

				<!-- Pricing Link -->
				<a href="/pricing" class="text-xs font-medium text-neutral-600 hover:text-brand transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 rounded px-2 py-1 uppercase tracking-wider">
					Pricing
				</a>

				<!-- Trainings Link -->
				<a href="/trainings" class="text-xs font-medium text-neutral-600 hover:text-brand transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 rounded px-2 py-1 uppercase tracking-wider">
					Trainings
				</a>

				<!-- Retreats Link -->
				<a href="/retreats" class="text-xs font-medium text-neutral-600 hover:text-brand transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 rounded px-2 py-1 uppercase tracking-wider">
					Retreats
				</a>
			</div>

			<!-- Center: Logo -->
			<div class="flex justify-start xl:justify-center flex-1 xl:flex-none xl:col-span-1">
				<a href="/" class="flex items-center hover:opacity-90 transition-all duration-300">
					<img
						src={logoImage.src}
						alt="Love More - Movement, Community, Connection"
						:class="scrolled ? 'h-8' : 'h-11'"
						class="w-auto transition-all duration-300"
					/>
				</a>
			</div>

			<!-- Right: About, Contact, and Button -->
			<div class="hidden xl:flex items-center justify-end gap-8 xl:col-span-1">
				<!-- About Dropdown -->
				<div x-data="{ open: false }" class="relative">
					<button
						@mouseenter="open = true"
						@mouseleave="open = false"
						@keydown.escape="open = false"
						:aria-expanded="open"
						aria-haspopup="true"
						aria-controls="about-menu"
						class="flex items-center gap-1 text-xs font-medium text-neutral-600 hover:text-brand transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 rounded px-2 py-1 uppercase tracking-wider"
					>
						<span>About</span>
						<svg class="w-3 h-3" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
						</svg>
					</button>
					<div
						x-show="open"
						@mouseenter="open = true"
						@mouseleave="open = false"
						x-transition:enter="transition ease-out duration-200"
						x-transition:enter-start="opacity-0 scale-95"
						x-transition:enter-end="opacity-100 scale-100"
						x-transition:leave="transition ease-in duration-150"
						x-transition:leave-start="opacity-100 scale-100"
						x-transition:leave-end="opacity-0 scale-95"
						id="about-menu"
						class="absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg border border-warm-gray-200 py-2 z-50"
						style="display: none;"
					>
						<a href="/team" class="block px-4 py-2 text-sm text-neutral-700 hover:bg-cream-200 hover:text-brand transition-colors">Our Team</a>
						<a href="/start" class="block px-4 py-2 text-sm text-neutral-700 hover:bg-cream-200 hover:text-brand transition-colors">New to Yoga / Getting Started</a>
						<a href="/faqs" class="block px-4 py-2 text-sm text-neutral-700 hover:bg-cream-200 hover:text-brand transition-colors">FAQs</a>
						<a href="/about" class="block px-4 py-2 text-sm text-neutral-700 hover:bg-cream-200 hover:text-brand transition-colors">Our Story / The Three Pillars</a>
					</div>
				</div>

				<!-- Contact Link -->
				<a href="/contact" class="text-xs font-medium text-neutral-600 hover:text-brand transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 rounded px-2 py-1 uppercase tracking-wider">
					Contact
				</a>

				<div :class="scrolled ? 'scale-90' : 'scale-100'" class="transition-transform duration-300">
					<Button href="/start" size="small">
						<span class="hidden 2xl:inline">Get Started for $56</span>
						<span class="inline 2xl:hidden">Start for $56</span>
					</Button>
				</div>
			</div>

			<!-- Mobile Menu Button -->
			<button
				x-data="{ open: false }"
				@click="open = !open; $dispatch('mobile-menu-toggle', { open })"
				aria-label="Toggle mobile menu"
				:aria-expanded="open"
				aria-controls="mobile-menu"
				class="xl:hidden p-2 text-neutral-600 hover:text-brand transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand rounded col-start-3 justify-self-end"
			>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
				</svg>
			</button>
		</div>
	</div>

	<!-- Mobile Menu Panel -->
	<div
		x-data="{ open: false }"
		@mobile-menu-toggle.window="open = $event.detail.open"
		@keydown.escape.window="open = false"
		x-show="open"
		x-transition:enter="transition ease-out duration-200"
		x-transition:enter-start="opacity-0 -translate-y-4"
		x-transition:enter-end="opacity-100 translate-y-0"
		x-transition:leave="transition ease-in duration-150"
		x-transition:leave-start="opacity-100 translate-y-0"
		x-transition:leave-end="opacity-0 -translate-y-4"
		id="mobile-menu"
		class="xl:hidden bg-cream-100 border-t border-warm-gray-200 shadow-md"
		style="display: none;"
	>
		<div class="container mx-auto px-6 py-4 space-y-4">
			<!-- Mobile Schedule Section -->
			<div x-data="{ expanded: false }">
				<button
					@click="expanded = !expanded"
					:aria-expanded="expanded"
					class="flex items-center justify-between w-full text-left text-sm font-medium text-neutral-600 hover:text-brand py-2 uppercase tracking-wider"
				>
					Schedule
					<svg x-show="!expanded" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
					</svg>
					<svg x-show="expanded" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="display: none;">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>
					</svg>
				</button>
				<div x-show="expanded" x-collapse class="pl-4 space-y-2 mt-2">
					<a href="/schedule" class="block py-2 text-sm text-neutral-600 hover:text-brand">Book a Class</a>
					<a href="/studio-classes" class="block py-2 text-sm text-neutral-600 hover:text-brand">Class Descriptions</a>
					<a href="/specialty-classes" class="block py-2 text-sm text-neutral-600 hover:text-brand">Specialty Events & Workshops</a>
					<a href="/virtual-studio" class="block py-2 text-sm text-neutral-600 hover:text-brand">Virtual Studio</a>
				</div>
			</div>

			<!-- Mobile Pricing Link -->
			<a href="/pricing" class="block text-sm font-medium text-neutral-600 hover:text-brand py-2 uppercase tracking-wider">
				Pricing
			</a>

			<!-- Mobile Trainings Link -->
			<a href="/trainings" class="block text-sm font-medium text-neutral-600 hover:text-brand py-2 uppercase tracking-wider">
				Trainings
			</a>

			<!-- Mobile Retreats Link -->
			<a href="/retreats" class="block text-sm font-medium text-neutral-600 hover:text-brand py-2 uppercase tracking-wider">
				Retreats
			</a>

			<!-- Mobile About Section -->
			<div x-data="{ expanded: false }">
				<button
					@click="expanded = !expanded"
					:aria-expanded="expanded"
					class="flex items-center justify-between w-full text-left text-sm font-medium text-neutral-600 hover:text-brand py-2 uppercase tracking-wider"
				>
					About
					<svg x-show="!expanded" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
					</svg>
					<svg x-show="expanded" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="display: none;">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>
					</svg>
				</button>
				<div x-show="expanded" x-collapse class="pl-4 space-y-2 mt-2">
					<a href="/team" class="block py-2 text-sm text-neutral-600 hover:text-brand">Our Team</a>
					<a href="/start" class="block py-2 text-sm text-neutral-600 hover:text-brand">New to Yoga / Getting Started</a>
					<a href="/faqs" class="block py-2 text-sm text-neutral-600 hover:text-brand">FAQs</a>
					<a href="/about" class="block py-2 text-sm text-neutral-600 hover:text-brand">Our Story / The Three Pillars</a>
				</div>
			</div>

			<!-- Mobile Contact Link -->
			<a href="/contact" class="block text-sm font-medium text-neutral-600 hover:text-brand py-2 uppercase tracking-wider">
				Contact
			</a>

			<!-- Mobile CTA -->
			<Button href="/start" size="small" class="w-full">
				Get Started for $56
			</Button>
		</div>
	</div>
</nav>

<!-- Skip to main content link for accessibility -->
<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:px-4 focus:py-2 focus:bg-red-700 focus:text-white focus:rounded focus:shadow-lg">
	Skip to main content
</a>
