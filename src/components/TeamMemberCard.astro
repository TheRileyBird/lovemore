---
interface Props {
	name: string;
	title: string;
	image: string;
	index: number;
	bio?: string;
}

const { name, title, image, index, bio } = Astro.props;
---

<div
	class="group cursor-pointer"
	data-member-index={index}
>
	<div class="relative">
		<div class="relative overflow-hidden rounded-2xl shadow-md aspect-square mb-10">
			<img
				src={image || '/images/icon.webp'}
				alt={name}
				loading="lazy"
				class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
			/>
		</div>

		<!-- Overlapping Name/Title Box -->
		<div class="absolute left-4 right-4 -bottom-8 bg-white text-center backdrop-blur-sm rounded-xl p-4 shadow-lg border border-warm-gray-200 transition-all duration-300 group-hover:shadow-xl group-hover:-translate-y-1">
			<h3 class="font-sans font-semibold text-sm uppercase text-charcoal leading-tight">{name}</h3>
			{title && (
				<p class="text-xs line-clamp-1 text-neutral-600 mt-1">{title}</p>
			)}
		</div>
	</div>

	<!-- Read Bio hint (appears on hover, only if bio exists) -->
	{bio && (
		<div class="mt-4 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
			<span class="text-brand text-sm font-medium">Read Bio →</span>
		</div>
	)}
</div>
