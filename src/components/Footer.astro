---
import iconImage from '../assets/images/icon.webp';
import { Instagram, Facebook, Heart } from 'lucide-astro';
import TikTok from './TikTok.astro';
---

<footer class="text-charcoal">
	<!-- Main Footer - Cream Background -->
	<section class="py-16 bg-cream-200 border-t border-warm-gray-200">
		<div class="container mx-auto px-6">
			<div class="max-w-6xl mx-auto">
				<!-- Flex Layout: Logo left, Columns right -->
				<div class="flex flex-col md:flex-row md:justify-between gap-12">
					<!-- Logo on the left -->
					<div class="flex justify-center md:justify-start">
						<img
							src={iconImage.src}
							alt="Love More"
							class="w-40 md:w-48"
						/>
					</div>

					<!-- Four Link Columns on the right -->
					<div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
						<!-- Explore Column -->
						<div>
							<h3 class="text-sm font-bold tracking-wider uppercase text-charcoal mb-6">Explore</h3>
							<ul class="space-y-3">
								<li><a href="/" class="text-sm text-neutral-600 hover:text-brand transition-colors">Home</a></li>
								<li><a href="/team" class="text-sm text-neutral-600 hover:text-brand transition-colors">Team</a></li>
								<li><a href="/events" class="text-sm text-neutral-600 hover:text-brand transition-colors">Events</a></li>
								<li><a href="/virtual-studio" class="text-sm text-neutral-600 hover:text-brand transition-colors">Virtual Studio</a></li>
							</ul>
						</div>

						<!-- Practice Column -->
						<div>
							<h3 class="text-sm font-bold tracking-wider uppercase text-charcoal mb-6">Practice</h3>
							<ul class="space-y-3">
								<li><a href="/studio-classes" class="text-sm text-neutral-600 hover:text-brand transition-colors">Studio Classes</a></li>
								<li><a href="/studio-classes#heated-classes" class="text-sm text-neutral-600 hover:text-brand transition-colors">Heated Classes</a></li>
								<li><a href="/healing-room-services" class="text-sm text-neutral-600 hover:text-brand transition-colors">Healing Room Services</a></li>
								<li><a href="/specialty-classes" class="text-sm text-neutral-600 hover:text-brand transition-colors">Events & Workshops</a></li>
								<li><a href="/schedule" class="text-sm text-neutral-600 hover:text-brand transition-colors">Schedule</a></li>
							</ul>
						</div>

						<!-- Connect Column -->
						<div>
							<h3 class="text-sm font-bold tracking-wider uppercase text-charcoal mb-6">Connect</h3>
							<ul class="space-y-3">
								<li><a href="/pricing" class="text-sm text-neutral-600 hover:text-brand transition-colors">Pricing</a></li>
								<li><a href="/retreats" class="text-sm text-neutral-600 hover:text-brand transition-colors">Retreats</a></li>
								<li><a href="/contact" class="text-sm text-neutral-600 hover:text-brand transition-colors">Contact</a></li>
								<li><a href="/start" class="text-sm text-neutral-600 hover:text-brand transition-colors">Get Started</a></li>
							</ul>
						</div>

						<!-- Contact Column -->
						<div>
							<h3 class="text-sm font-bold tracking-wider uppercase text-charcoal mb-6">Visit Us</h3>
							<ul class="space-y-3">
								<li>
									<a href="tel:985-900-2468" class="text-sm text-neutral-600 hover:text-brand transition-colors">985-900-2468</a>
								</li>
								<li class="text-sm text-neutral-600">
									234 Lee Lane<br />
									Covington, LA
								</li>
								<li>
									<div class="flex items-center gap-4 pt-2">
										<a href="https://facebook.com/lovemorecovington" target="_blank" rel="noopener noreferrer" class="text-charcoal hover:text-brand transition-colors" aria-label="Facebook">
											<Facebook class="w-5 h-5" />
										</a>
										<a href="https://instagram.com/lovemore_covington" target="_blank" rel="noopener noreferrer" class="text-charcoal hover:text-brand transition-colors" aria-label="Instagram">
											<Instagram class="w-5 h-5" />
										</a>
										<a href="https://www.tiktok.com/@lovemore_covington" target="_blank" rel="noopener noreferrer" class="text-charcoal hover:text-brand transition-colors" aria-label="TikTok">
											<TikTok class="w-5 h-5" />
										</a>
									</div>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Bottom Section - White Background -->
	<section class="py-8 bg-white border-t border-warm-gray-200">
		<div class="container mx-auto px-6">
			<div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-neutral-600">
				<div class="flex items-center">
					<span class="tracking-wider uppercase">Movement • Community • Connection</span>
				</div>
				<div>
					<span class="text-neutral-400 flex items-center gap-1">Crafted with <Heart class="w-3 h-3 fill-brand text-brand" /> by <a href="https://teamrileyweb.com" target="_blank" class="hover:text-brand transition-colors">Team Riley</a></span>
				</div>
			</div>
		</div>
	</section>
</footer>
