---
import iconImage from '../assets/images/icon.webp';
import { Instagram, Facebook, Heart } from 'lucide-astro';
---

<footer class="text-charcoal">
	<!-- Main Footer - Cream Background -->
	<section class="py-16 bg-cream-200 border-t border-warm-gray-200">
		<div class="container mx-auto px-6">
			<div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12">
				<!-- Left 50% - Icon and Social Only -->
				<div class="flex flex-col justify-between items-center md:items-start">
					<div>
						<img
							src={iconImage.src}
							alt="Love More"
							class="w-56"
						/>
					</div>
				</div>

				<!-- Right 50% - Three Columns of Links -->
				<div class="grid grid-cols-3 gap-8">
					<!-- Explore Column -->
					<div>
						<h3 class="text-sm font-bold tracking-wider uppercase text-charcoal mb-6">Explore</h3>
						<ul class="space-y-3">
							<li><a href="/" class="text-sm text-neutral-600 hover:text-brand transition-colors">Home</a></li>
							<li><a href="/about" class="text-sm text-neutral-600 hover:text-brand transition-colors">About</a></li>
							<li><a href="/events" class="text-sm text-neutral-600 hover:text-brand transition-colors">Events</a></li>
							<li><a href="/virtual" class="text-sm text-neutral-600 hover:text-brand transition-colors">Virtual Studio</a></li>
						</ul>
					</div>

					<!-- Practice With Us Column -->
					<div>
						<h3 class="text-sm font-bold tracking-wider uppercase text-charcoal mb-6">Practice</h3>
						<ul class="space-y-3">
							<li><a href="/studio-classes" class="text-sm text-neutral-600 hover:text-brand transition-colors">Studio Classes</a></li>
							<li><a href="/movement" class="text-sm text-neutral-600 hover:text-brand transition-colors">Movement</a></li>
							<li><a href="/schedule" class="text-sm text-neutral-600 hover:text-brand transition-colors">Schedule</a></li>
							<li><a href="/start" class="text-sm text-neutral-600 hover:text-brand transition-colors">Start for $56</a></li>
						</ul>
					</div>

					<!-- Customer Care Column -->
					<div>
						<h3 class="text-sm font-bold tracking-wider uppercase text-charcoal mb-6">Care</h3>
						<ul class="space-y-3">
							<li><a href="/faqs" class="text-sm text-neutral-600 hover:text-brand transition-colors">FAQs</a></li>
							<li><a href="/contact" class="text-sm text-neutral-600 hover:text-brand transition-colors">Contact</a></li>
							<li><a href="/terms" class="text-sm text-neutral-600 hover:text-brand transition-colors">Terms of service</a></li>
							<li><a href="/privacy" class="text-sm text-neutral-600 hover:text-brand transition-colors">Privacy</a></li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Bottom Section - White Background -->
	<section class="py-8 bg-white border-t border-warm-gray-200">
		<div class="container mx-auto px-6">
			<div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-neutral-600">
				<div class="flex flex-col md:flex-row items-center gap-4">
					<div class="flex items-center gap-4">
						<a href="https://facebook.com/lovemorecovington" target="_blank" rel="noopener noreferrer" class="text-charcoal hover:text-brand transition-colors" aria-label="Facebook">
							<Facebook class="w-5 h-5" />
						</a>
						<a href="https://instagram.com/lovemore_covington" target="_blank" rel="noopener noreferrer" class="text-charcoal hover:text-brand transition-colors" aria-label="Instagram">
							<Instagram class="w-5 h-5" />
						</a>
					</div>
					<span class="tracking-wider uppercase">Movement • Community • Connection</span>
				</div>
				<div>
					<span class="text-neutral-400 flex items-center gap-1">Crafted with <Heart class="w-3 h-3 fill-brand text-brand" /> by <a href="https://teamrileyweb.com" target="_blank" class="hover:text-brand transition-colors">Team Riley</a></span>
				</div>
			</div>
		</div>
	</section>
</footer>
