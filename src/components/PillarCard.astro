---
import { LucideIcon } from 'lucide-astro';
import { ArrowRight } from 'lucide-astro';

interface Props {
	icon: typeof LucideIcon;
	title: string;
	description: string;
	link: string;
	image: string;
	delay?: number;
}

const { icon: Icon, title, description, link, image } = Astro.props;
---

<div class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-lg transition-all duration-200 group">
	<!-- Image section -->
	<div class="relative h-64 overflow-hidden">
		<img
			src={image}
			alt={title}
			loading="lazy"
			class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
		/>
	</div>

	<!-- Content section -->
	<div class="p-8">
		<!-- Icon -->
		<div class="w-12 h-12 rounded-xl bg-gradient-to-br from-brand to-brand-dark flex items-center justify-center mb-4">
			<Icon class="w-6 h-6 text-white" />
		</div>

		<!-- Title -->
		<h3 class="text-3xl font-display font-light text-charcoal mb-3 tracking-wide">
			{title}
		</h3>

		<!-- Description -->
		<p class="text-neutral-600 leading-relaxed mb-6">
			{description}
		</p>

		<!-- Link -->
		<a href={link} class="inline-flex items-center gap-2 text-brand font-medium hover:gap-3 transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 rounded">
			Discover More
			<ArrowRight class="w-4 h-4" />
		</a>
	</div>
</div>
