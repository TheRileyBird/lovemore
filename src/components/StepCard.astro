---
interface Props {
	number: number;
	title: string;
	description: string;
	delay?: number;
}

const { number, title, description } = Astro.props;
---

<div class="text-center">
	<!-- Large Number -->
	<div>
		<span class="text-[12rem] md:text-[16rem] font-light text-charcoal/80 leading-none block" style="font-family: var(--font-logo);">{number}</span>
	</div>

	<!-- Description Text -->
	<p class="text-xl md:text-2xl text-charcoal font-light leading-relaxed max-w-xs mx-auto">{description}</p>
</div>
