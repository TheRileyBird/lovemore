---
interface Props {
	number: number;
	title: string;
	description: string;
	delay?: number;
}

const { number, title, description } = Astro.props;

// Background images for each step
const stepImages = [
	'https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=800&h=1000&fit=crop&q=80',
	'https://images.unsplash.com/photo-1588286840104-8957b019727f?w=800&h=1000&fit=crop&q=80',
	'https://images.unsplash.com/photo-1545389336-cf090694435e?w=800&h=1000&fit=crop&q=80'
];
---

<a
	href="/start"
	class="group relative overflow-hidden rounded-3xl shadow-2xl hover:shadow-[0_20px_60px_-15px_rgba(212,175,55,0.4)] transition-all duration-700 hover:-translate-y-3 block focus:outline-none focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2"
>
	<div class="absolute inset-0">
		<img
			src={stepImages[number - 1]}
			alt=""
			loading="lazy"
			class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000"
		/>
		<div class="absolute inset-0 bg-gradient-to-t from-neutral-900/95 via-neutral-900/70 to-neutral-900/40"></div>
		<!-- Subtle gold overlay on hover -->
		<div class="absolute inset-0 bg-gradient-to-t from-gold/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
	</div>

	<div class="relative p-10 min-h-[550px] flex flex-col justify-center items-center">
		<!-- Large Number Centered -->
		<div class="text-center flex-1 flex items-center justify-center">
			<span class="text-[14rem] md:text-[18rem] font-light text-brand/60 group-hover:text-brand/90 leading-none block transition-colors duration-500" style="font-family: var(--font-logo);">{number}</span>
		</div>

		<!-- Content at Bottom -->
		<div class="text-center mt-auto">
			<!-- Title -->
			<p class="text-sm font-medium tracking-wider uppercase text-gold mb-3">{title}</p>

			<!-- Description -->
			<p class="text-base text-white/90 leading-relaxed font-light">{description}</p>
		</div>
	</div>
</a>
