---
interface Props {
	number: number;
	title: string;
	description: string;
	delay?: number;
}

const { number, title, description } = Astro.props;
---

<div class="relative group h-full">
	<!-- Gold glow on hover -->
	<div class="absolute -inset-2 bg-gradient-to-r from-gold/30 via-brand/20 to-gold/30 rounded-3xl opacity-0 group-hover:opacity-100 blur-xl transition-all duration-700"></div>

	<div class="relative bg-white p-10 rounded-3xl shadow-luxury hover:shadow-2xl transition-all duration-500 border border-gold/10 hover:border-gold/30 hover:-translate-y-2 h-full flex flex-col">
		<!-- Number - Large and Centered -->
		<div class="flex items-center justify-center mb-8">
			<span class="text-8xl font-display font-light text-charcoal/20 group-hover:text-charcoal/30 transition-colors duration-500">{number}</span>
		</div>

		<h3 class="text-sm font-semibold text-charcoal mb-4 uppercase tracking-wider">{title}</h3>
		<p class="text-neutral-600 leading-relaxed text-lg font-light flex-grow">{description}</p>
	</div>
</div>
