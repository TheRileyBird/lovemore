---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
import { Palmtree } from 'lucide-astro';
import { fetchAPI, getStrapiMedia } from '../../lib/strapi';
import { marked } from 'marked';

export async function getStaticPaths() {
	// Helper to handle both HTML and Markdown content
	function processContent(content: string): string {
		if (!content) return '';
		// If content contains HTML tags, return as-is
		if (content.includes('<p>') || content.includes('<strong>')) {
			return content;
		}
		// Otherwise treat as Markdown
		return marked(content);
	}

	try {
		const retreatsResponse = await fetchAPI<any>({
			endpoint: 'retreats',
			query: {
				// Fetch ALL retreats (past and future) to avoid 404s
				'populate': '*'
			},
			wrappedByKey: 'data'
		});

		if (!retreatsResponse || retreatsResponse.length === 0) {
			console.warn('No retreats found in Strapi - returning empty array');
			return [];
		}

		// Filter out retreats without slugs
		const validRetreats = retreatsResponse.filter((retreat: any) => retreat.slug);

		if (validRetreats.length === 0) {
			console.warn('No retreats with valid slugs found - returning empty array');
			return [];
		}

		return validRetreats.map((retreat: any) => ({
			params: { slug: retreat.slug },
			props: {
				retreat: {
					...retreat,
					image: retreat.image?.url ? getStrapiMedia(retreat.image.url) : null,
					body: processContent(retreat.body),
					gallery: retreat.gallery?.map((img: any) => ({
						url: getStrapiMedia(img.url),
						alternativeText: img.alternativeText || retreat.name
					})) || [],
					ctaButtonLabel: retreat.ctaButtonLabel,
					ctaButtonUrl: retreat.ctaButtonUrl
				}
			}
		}));
	} catch (error) {
		console.error('Error fetching retreats for static paths:', error);
		return [];
	}
}

const { retreat } = Astro.props;

// Check if retreat has passed
const isPastEvent = retreat.endDate && new Date(retreat.endDate) < new Date();
---

<Layout title={`${retreat.name} — Love More`}>
	<Navigation />

	<main id="main-content">
		<!-- Hero Section with Image -->
		<section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="retreat-heading">
			<div class="absolute inset-0 z-0">
				<img
					src={retreat.image || 'https://images.squarespace-cdn.com/content/v1/59d53a9459cc683b30818a39/1698857393487-I0M9VNSSDU0WURO47UYG/IMG_5194.jpeg?format=1600w'}
					alt={retreat.name}
					class="absolute inset-0 w-full h-full object-cover"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/70 via-neutral-900/60 to-neutral-900/70"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<h1 id="retreat-heading" class="text-4xl md:text-6xl font-display font-bold text-white tracking-wide mb-4">
					{retreat.name}
				</h1>
				{retreat.subtitle && (
					<p class="text-xl md:text-2xl text-white/90 font-light mb-2">{retreat.subtitle}</p>
				)}
				<p class="text-2xl text-white/95 font-light">{retreat.location}</p>
			</div>
		</section>

		<!-- Content Section -->
		<section class="py-20 bg-cream">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					{/* Past Event Banner */}
					{isPastEvent && (
						<div class="mb-8 p-6 bg-neutral-100 border border-neutral-300 rounded-xl">
							<p class="text-neutral-700 text-center font-medium">
								⏰ This retreat has passed. Check out our <a href="/retreats" class="text-brand hover:underline">upcoming retreats</a>.
							</p>
						</div>
					)}

					<div class="grid grid-cols-1 lg:grid-cols-[350px_1fr] gap-8 mb-12">
						{retreat.image && (
							<div class="lg:sticky lg:top-24 h-fit">
								<img
									src={retreat.image}
									alt={retreat.name}
									class="w-full h-auto rounded-lg"
								/>
							</div>
						)}

						<div class="prose prose-lg max-w-none [&_p]:text-neutral-600 [&_p]:text-base [&_p]:leading-relaxed [&_p]:mb-4 [&_h2]:font-display [&_h2]:text-2xl [&_h2]:md:text-3xl [&_h2]:font-bold [&_h2]:text-brand [&_h2]:tracking-wide [&_h2]:mb-4 [&_h2]:mt-12 [&_h2:first-child]:mt-0 [&_h3]:font-display [&_h3]:text-xl [&_h3]:md:text-2xl [&_h3]:font-semibold [&_h3]:text-brand [&_h3]:tracking-wide [&_h3]:mb-3 [&_h3]:mt-10 [&_h3:first-child]:mt-0 [&_ul]:text-neutral-600 [&_ul]:text-base [&_ul]:mb-6 [&_ul]:list-disc [&_ul]:pl-6 [&_li]:mb-2 [&_strong]:text-charcoal [&_strong]:font-semibold" set:html={retreat.body} />
					</div>

					<!-- Buttons -->
					<div class="flex flex-col mb-12 sm:flex-row gap-4 justify-center">
						{retreat.ctaButtonLabel && retreat.ctaButtonUrl ? (
							<Button href={retreat.ctaButtonUrl} variant="primary" size="large">
								{retreat.ctaButtonLabel}
							</Button>
						) : (
							<Button href="/contact" variant="primary" size="large">
								Request More Information
							</Button>
						)}
						<a
							href="/retreats"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
						>
							View All Retreats
						</a>
					</div>

					{/* Gallery Grid */}
					{retreat.gallery && retreat.gallery.length > 0 && (
						<div class={`grid gap-4 mb-12 ${
							retreat.gallery.length === 1 ? 'grid-cols-1 max-w-md mx-auto' :
							retreat.gallery.length === 2 ? 'grid-cols-1 md:grid-cols-2' :
							retreat.gallery.length === 3 ? 'grid-cols-1 md:grid-cols-3' :
							'grid-cols-2 md:grid-cols-4'
						}`}>
							{retreat.gallery.map((image: any) => (
								<div class="aspect-square overflow-hidden rounded-lg">
									<img
										src={image.url}
										alt={image.alternativeText}
										class="w-full h-full object-cover"
									/>
								</div>
							))}
						</div>
					)}
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
