---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import EventDetailHero from '../../components/EventDetailHero.astro';
import EventDetailLayout from '../../components/EventDetailLayout.astro';
import { Palmtree } from 'lucide-astro';
import { fetchAPI, getStrapiMedia } from '../../lib/strapi';
import { marked } from 'marked';

export async function getStaticPaths() {
	// Helper to handle both HTML and Markdown content
	function processContent(content: string): string {
		if (!content) return '';
		// If content contains HTML tags, return as-is
		if (content.includes('<p>') || content.includes('<strong>')) {
			return content;
		}
		// Otherwise treat as Markdown
		return marked(content);
	}

	try {
		const retreatsResponse = await fetchAPI<any>({
			endpoint: 'retreats',
			query: {
				// Fetch ALL retreats (past and future) to avoid 404s
				'populate': '*'
			},
			wrappedByKey: 'data'
		});

		if (!retreatsResponse || retreatsResponse.length === 0) {
			console.warn('No retreats found in Strapi - returning empty array');
			return [];
		}

		// Filter out retreats without slugs
		const validRetreats = retreatsResponse.filter((retreat: any) => retreat.slug);

		if (validRetreats.length === 0) {
			console.warn('No retreats with valid slugs found - returning empty array');
			return [];
		}

		return validRetreats.map((retreat: any) => ({
			params: { slug: retreat.slug },
			props: {
				retreat: {
					...retreat,
					image: retreat.image?.url ? getStrapiMedia(retreat.image.url) : null,
					body: processContent(retreat.body),
					gallery: retreat.gallery?.map((img: any) => ({
						url: getStrapiMedia(img.url),
						alternativeText: img.alternativeText || retreat.name
					})) || [],
					ctaButtonLabel: retreat.ctaButtonLabel,
					ctaButtonUrl: retreat.ctaButtonUrl
				}
			}
		}));
	} catch (error) {
		console.error('Error fetching retreats for static paths:', error);
		return [];
	}
}

const { retreat } = Astro.props;

// Check if retreat has passed
const isPastEvent = retreat.endDate && new Date(retreat.endDate) < new Date();

// Format dates for display
const formatDate = (date: string) => {
	return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};
const dateDisplay = retreat.startDate && retreat.endDate
	? `${formatDate(retreat.startDate)} - ${formatDate(retreat.endDate)}`
	: retreat.startDate
		? formatDate(retreat.startDate)
		: retreat.endDate
			? formatDate(retreat.endDate)
			: '';
---

<Layout title={`${retreat.name} — Love More`}>
	<Navigation />

	<main id="main-content">
		<EventDetailHero
			title={retreat.name}
			subtitle={retreat.subtitle}
			location={retreat.location}
			image={retreat.image}
			icon={Palmtree}
			dateDisplay={dateDisplay}
		/>

		<EventDetailLayout
			title={retreat.name}
			subtitle={retreat.subtitle}
			location={retreat.location}
			image={retreat.image}
			body={retreat.body}
			gallery={retreat.gallery}
			startDate={retreat.startDate}
			endDate={retreat.endDate}
			isPastEvent={isPastEvent}
			ctaButtonLabel={retreat.ctaButtonLabel}
			ctaButtonUrl={retreat.ctaButtonUrl}
			backLink="/retreats"
			backLinkText="View All Retreats"
		/>
	</main>

	<Footer />
</Layout>
