---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { Video, Calendar } from 'lucide-astro';
import virtualBanner from '../assets/images/class.jpg';
---

<Layout title="Virtual Studio — Love More">
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="virtual-heading">
			<div class="absolute inset-0 z-0">
				<img
					src={virtualBanner.src}
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<Video class="w-14 h-14 text-brand mx-auto mb-6 opacity-90" aria-hidden="true" />
				<h1 id="virtual-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide mb-4">
					Virtual Studio
				</h1>
				<p class="text-2xl text-white/90 font-light">
					Practice Anywhere, Anytime
				</p>
			</div>
		</section>

		<!-- Video Library Section -->
		<section class="py-16 bg-cream-50" aria-labelledby="videos-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<div class="text-center mb-8">
						<h2 id="videos-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
							On-Demand Videos
						</h2>
						<p class="text-lg text-neutral-600">
							Access our library of recorded classes and practice at your own pace.
						</p>
					</div>

					<div class="bg-white rounded-2xl shadow-md overflow-hidden" style="min-height: 600px;">
						<iframe
							id="videoLibraryIframe"
							src="https://app.arketa.co/iframe/theinvitation/videos?showFeatured=true"
							width="100%"
							style="height: 1050px; border: none;"
							frameborder="0"
							allow="payment;fullscreen"
							allowfullscreen
							title="Virtual Studio Video Library"
						></iframe>
					</div>
				</div>
			</div>
		</section>

		<!-- Live Schedule Section -->
		<section class="py-16 bg-white" aria-labelledby="schedule-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<div class="text-center mb-8">
						<Calendar class="w-12 h-12 text-brand mx-auto mb-4" aria-hidden="true" />
						<h2 id="schedule-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
							Live Virtual Classes
						</h2>
						<p class="text-lg text-neutral-600">
							Join us for live-streamed classes and connect with our community in real-time.
						</p>
					</div>

					<div class="bg-white rounded-2xl shadow-md overflow-hidden" style="min-height: 800px;">
						<iframe
							id="virtualScheduleIframe"
							src="https://app.arketa.co/iframe/theinvitation/schedule"
							width="100%"
							style="height: 800px; border: none;"
							frameborder="0"
							allow="payment"
							allowfullscreen
							title="Virtual Studio Live Schedule"
						></iframe>
					</div>
				</div>
			</div>
		</section>

		<!-- Call to Action -->
		<section class="py-20 bg-cream">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Prefer In-Person?
					</h2>
					<p class="text-lg text-neutral-600 mb-8 leading-relaxed">
						Nothing beats the energy of practicing together in our studio. Check out our in-studio schedule and join us on the mat.
					</p>
					<a
						href="/schedule"
						class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-brand text-white hover:bg-brand-dark hover:shadow-lg px-8 py-4 text-base"
					>
						View Studio Schedule
					</a>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
