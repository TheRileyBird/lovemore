function processContent(content: string): string {
	if (!content) return '';
	if (content.includes('<p>') || content.includes('<strong>')) return content;
	return marked(content);
}

const teamMembers = team.map(m => ({ ...m, bio: processContent(m.bio) }));
const modalTeamMembers = teamMembers.map(member => ({
	...member,
	image: member.image?.src ?? fallbackIcon.src,
}));
---

<Layout title="Team — Love More">
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="team-heading">
			<div class="absolute inset-0 z-0">
				<img
					src={heroImage.src}
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
					style="object-position: 100% 40%;"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<h1 id="team-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide mb-6">
					Meet Our Team
				</h1>
			</div>
		</section>

		<!-- Intro Section -->
		<section class="py-20 bg-linear-to-b from-cream to-white" aria-labelledby="intro-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-4xl mx-auto text-center">
					<h2 id="intro-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
						Helping you to <strong>LOVE MORE</strong> - Everyday
					</h2>
					<Divider width="short" class="mb-8" />
					<p class="text-lg text-neutral-600 leading-relaxed">
						Welcome to Love More, where the journey of self-discovery and holistic well-being begins. Our studio stands as a haven for seekers of balance, mindfulness, and inner harmony. With a shared passion for nurturing both body and soul, our diverse team of dedicated instructors comes together to guide you on a transformative voyage through the art of yoga. At Love More, we believe in cultivating not only physical strength and flexibility but also a profound love and acceptance for oneself and others. Join us as we embark on towards a life enriched by movement, connection, and community.
					</p>
				</div>
			</div>
		</section>

		<!-- Team Grid Section -->
		<section class="pb-24 bg-linear-to-b from-white to cream" aria-labelledby="instructors-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-7xl mx-auto">
					<div class="grid md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-8">
						{teamMembers.map((member: any, index: number) => (
							<TeamMemberCard
								name={member.name}
								title={member.title}
								image={member.image}
								index={index}
								bio={member.bio}
							/>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Team Member Modal -->
		<TeamMemberModal />

		<!-- CTA Section -->
		<section class="pb-20 bg-cream">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Ready to Begin Your Journey?
					</h2>
					<p class="text-lg text-neutral-600 mb-8 leading-relaxed">
						Join our warm and welcoming community. Our teachers are here to guide and support you every step of the way.
					</p>
					<a
						href="/start"
						class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-charcoal text-white hover:bg-brand hover:shadow-lg px-8 py-4 text-base"
					>
						Start Your Practice
					</a>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<script define:vars={{ teamMembers: modalTeamMembers }}>
	// Store team members data in JavaScript
	const members = teamMembers;

	// Add click handlers after DOM loads
	document.addEventListener('alpine:init', () => {
		// Wait for Alpine to be ready
		setTimeout(() => {
			const cards = document.querySelectorAll('[data-member-index]');
			cards.forEach((card) => {
				card.addEventListener('click', () => {
					const index = parseInt(card.getAttribute('data-member-index'));
					const member = members[index];
					// Dispatch custom event with member data
					window.dispatchEvent(new CustomEvent('modal-open', { detail: member }));
				});
			});
		}, 100);
	});
</script>
