---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Divider from '../components/Divider.astro';
import TeamMemberModal from '../components/TeamMemberModal.astro';

// Import team data from scraped content
import teamData from '../../scraped-content/team.json';

// Extract team members from sections and add placeholder bios
const teamMembers = teamData.sections
	.filter((section: any) => section.type === 'image' && section.image)
	.map((section: any) => {
		const lines = section.text.split('\n').filter((line: string) => line.trim());
		const name = lines[0] || '';
		const title = lines[1] || '';

		// Placeholder bio text (to be replaced with actual content via CMS)
		const bio = `${name} is a passionate yoga instructor dedicated to helping students discover the transformative power of movement and mindfulness. With years of experience and a deep commitment to the Love More community, ${name.split(' ')[0]} creates a welcoming and supportive environment for practitioners of all levels. Their classes blend traditional wisdom with modern approaches, emphasizing the connection between breath, body, and spirit.`;

		return {
			name,
			title,
			image: section.image.src,
			bio
		};
	});
---

<Layout title="Team — Love More">
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="team-heading">
			<div class="absolute inset-0 z-0">
				<img
					src="https://images.squarespace-cdn.com/content/v1/59d53a9459cc683b30818a39/1698857393487-I0M9VNSSDU0WURO47UYG/IMG_5194.jpeg?format=1600w"
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
					style="object-position: 100% 40%;"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<h1 id="team-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide mb-6">
					Meet Our Team
				</h1>
			</div>
		</section>

		<!-- Intro Section -->
		<section class="py-20 bg-cream" aria-labelledby="intro-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-4xl mx-auto text-center">
					<h2 id="intro-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
						Helping you to <strong>LOVE MORE</strong> - Everyday
					</h2>
					<Divider width="short" class="mb-8" />
					<p class="text-lg text-neutral-600 leading-relaxed">
						Welcome to Love More, where the journey of self-discovery and holistic well-being begins. Our studio stands as a haven for seekers of balance, mindfulness, and inner harmony. With a shared passion for nurturing both body and soul, our diverse team of dedicated instructors comes together to guide you on a transformative voyage through the art of yoga. At Love More, we believe in cultivating not only physical strength and flexibility but also a profound love and acceptance for oneself and others. Join us as we embark on towards a life enriched by movement, connection, and community.
					</p>
				</div>
			</div>
		</section>

		<!-- Team Grid Section -->
		<section class="py-24 bg-white" aria-labelledby="instructors-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-7xl mx-auto">
					<h2 id="instructors-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-12 text-center tracking-wide">
						Our Instructors
					</h2>

					<div class="grid md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-16">
						{teamMembers.map((member: any) => (
							<div
								class="group cursor-pointer"
								@click={`$dispatch('modal-open', ${JSON.stringify(member)})`}
							>
								<div class="relative">
									<div class="relative overflow-hidden rounded-2xl shadow-md aspect-square mb-10">
										<img
											src={member.image}
											alt={member.name}
											loading="lazy"
											class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
										/>
									</div>

									<!-- Overlapping Name/Title Box -->
									<div class="absolute left-4 right-4 -bottom-8 bg-white text-center backdrop-blur-sm rounded-xl p-4 shadow-lg border border-warm-gray-200 transition-all duration-300 group-hover:shadow-xl group-hover:-translate-y-1">
										<h3 class="font-sans font-semibold text-sm uppercase text-charcoal leading-tight">{member.name}</h3>
										{member.title && (
											<p class="text-xs line-clamp-1 text-neutral-600 mt-1">{member.title}</p>
										)}
									</div>
								</div>

								<!-- Read Bio hint (appears on hover) -->
								<div class="mt-4 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
									<span class="text-brand text-sm font-medium">Read Bio →</span>
								</div>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Team Member Modal -->
		<TeamMemberModal />

		<!-- CTA Section -->
		<section class="py-20 bg-cream">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Ready to Begin Your Journey?
					</h2>
					<p class="text-lg text-neutral-600 mb-8 leading-relaxed">
						Join our warm and welcoming community. Our teachers are here to guide and support you every step of the way.
					</p>
					<a
						href="/start"
						class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-charcoal text-white hover:bg-brand hover:shadow-lg px-8 py-4 text-base"
					>
						Start Your Practice
					</a>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
