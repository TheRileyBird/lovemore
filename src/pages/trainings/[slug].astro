---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import EventDetailHero from '../../components/EventDetailHero.astro';
import EventDetailLayout from '../../components/EventDetailLayout.astro';
import { GraduationCap } from 'lucide-astro';
import { marked } from 'marked';
import type { ImageMetadata } from 'astro';

interface Training {
	title: string;
	subtitle: string | null;
	slug: string;
	startDate: string;
	endDate: string;
	price: number | null;
	flyerImage: ImageMetadata | null;
	headerImage: ImageMetadata | null;
	ctaText: string | null;
	ctaLink: string | null;
	body: string;
}

function getTrainingImage(path: string): ImageMetadata {
	const images = import.meta.glob('../../assets/images/trainings/*.{jpg,jpeg,png,webp}', { eager: true, import: 'default' }) as Record<string, ImageMetadata>;
	const image = images[path];
	if (!image) throw new Error(`Missing training image: ${path}`);
	return image;
}

function getTrainings(): Training[] {
	return [
  {
    title: "200HR-RYT Yoga Teacher Training",
    subtitle: "at Hattiesburg Hot Yoga",
    slug: "hattiesburg-ytt",
    startDate: "2026-09-11",
    endDate: "2027-03-21",
    price: 3250,
    flyerImage: getTrainingImage("../../assets/images/trainings/HtsburgYTT.jpg"),
    headerImage: getTrainingImage("../../assets/images/trainings/HtsburgYTT.jpg"),
    ctaText: "Sign Up & Explore Payment Options",
    ctaLink: "https://www.wellnessliving.com/rs/event/lovemore?k_class=966114&k_class_tab=39794",
    body: `Step Into the Journey of A Lifetime. . .a deeper understanding to your yoga practice and your own personal self.

This training is through Love More University and held at Hattiesburg Hot Yoga in Hattiesburg, MS.

Get Certified in 8 Weekends!

Dates for the next session are:

- September 11th–13th
- October 2nd–4th
- November 6th–8th
- December 4th–6th
- January 8th–10th, 2027
- January 22nd–24th
- February 26th–28th
- March 19th–21st *(Graduation Weekend)*

Fridays from 5:00pm–9:00pm

Saturdays from 8:00am–8:00pm

Sundays from 8:00am–3:00pm

This 200+ hour yoga teacher training is designed to take your personal practice and understanding of yoga to a whole new level and provide you with the skillset to offer students an intelligent, dynamic and inspiring yoga class. The course is ideal for serious students and aspiring teachers. With thousands of hours of teaching experience, this teacher training program will provide an in-depth exploration into the practice, process and science of yoga.

The day consists of lecture time, meditation, posture clinics, self study, practice teaching and asana practice. Topics covered include: Detailed, alignment-based posture clinics, Multiple methods of sequencing a Vinyasa class, Meditation, Philosophy of yoga, Physical and energetic anatomy, Heat management, Daily physical practice.

This training is designed to adequately prepare you to teach a dynamic and inspiring vinyasa yoga class.

You will have a vinyasa sequence that you are prepared to deliver in a safe and professional manner as well as be able to modify or intensify this sequence depending on your audience.

You will have the information to build your own sequences, understanding the how and why in creating a class.

You will understand yourself better and have a more informed personal practice.

You will have completed all of the requirements of a Yoga Alliance Recognized Teacher Training program and be qualified to request registration with Yoga Alliance.`,
  },
  {
    title: "200+ RYT Yoga Teacher Training with ayurveda philosophy & asanas",
    subtitle: null,
    slug: "training",
    startDate: "2027-02-19",
    endDate: "2027-07-25",
    price: 3250,
    flyerImage: getTrainingImage("../../assets/images/trainings/training.jpg"),
    headerImage: getTrainingImage("../../assets/images/trainings/training-header.jpg"),
    ctaText: "Sign Up & Explore Payment Options",
    ctaLink: "https://www.wellnessliving.com/rs/event/lovemore?k_class=963493&k_class_tab=39794",
    body: `Step Into the Journey of A Lifetime. . .a deeper understanding to your yoga practice and your own personal self.

This training is through Love More University and held at Love More studio in beautiful downtown Covington, LA.

Get Certified in just 8 weekends!

Dates for the 2027 session are:

February 19th-21st

March 5th-7th

March 19th-21st

April 16th-18th

May 14th-16th

June 4th-6th

June 25th-27th

July 9th-11th** (Ayurveda Training)

July 23rd-25th (Graduation)

Fridays from 5p-9pm
Saturdays from 8a-8pm
Sundays from 8a-4pm

This 200+ hour yoga teacher training is designed to take your personal practice and understanding of yoga to a whole new level and provide you with the skillset to offer students an intelligent, dynamic and inspiring yoga class. The course is ideal for serious students and aspiring teachers. With thousands of hours of teaching experience, this teacher training program will provide an in-depth exploration into the practice, process and science of yoga.

The day consists of lecture time, meditation, posture clinics, self study, practice teaching and asana practice. Topics covered include: Detailed, alignment-based posture clinics, Multiple methods of sequencing a Vinyasa class, Meditation, Philosophy of yoga, Physical and energetic anatomy, Heat management, Daily physical practice.

**This includes an added 25 hour module of Ayurveda training where you will gain deep insights into Ayurvedic philosophy and principles, including doshas and lifestyle, empowering you to integrate this ancient wisdom into your own wellbeing and teaching practice. (If you are unable to attend this weekend, you are able to make it up during the next session offered.)

This training is designed to adequately prepare you to teach a dynamic and inspiring vinyasa yoga class.

You will have a vinyasa sequence that you are prepared to deliver in a safe and professional manner as well as be able to modify or intensify this sequence depending on your audience.

You will have the information to build your own sequences, understanding the how and why in creating a class.

You will understand yourself better and have a more informed personal practice.

You will have completed all of the requirements of a Yoga Alliance Recognized Teacher Training program and be qualified to request registration with Yoga Alliance.`,
  },
  {
    title: "25-hr Hands-on Assisting",
    subtitle: null,
    slug: "25-hr-hands-on-assisting",
    startDate: "2026-08-28",
    endDate: "2026-08-30",
    price: 400,
    flyerImage: getTrainingImage("../../assets/images/trainings/25-hr-hands-on-assisting.jpg"),
    headerImage: getTrainingImage("../../assets/images/trainings/25-hr-hands-on-assisting-header.jpg"),
    ctaText: "Learn More",
    ctaLink: "https://hotasanastudio.com/teacher-training/25-hours-hands-on-assisting-love-more-covington-la",
    body: `## Deepen your teaching from the inside out.

This 25-hour training is dedicated to the art and skill of hands-on assists—helping you cultivate presence, refine your touch, and create safe, empowering adjustments in every class. You’ll explore anatomical and energetic alignment, practice assists for common postures, and learn how to use touch as a tool for guidance and support rather than correction.

Led by JoEllen Luke and Teresa Cantrelle, this immersive experience will help you strengthen your intuition, sharpen your observation skills, and grow your confidence in offering hands-on support. Expect a weekend filled with learning, feedback, and connection that will elevate both your teaching and your students’ experience.

### Dates:
- August 28-30, 2026

### Times:
- Fridays: 5 AM – 9 PM
- Saturdays: 8 AM – 8 PM
- Sundays: 8 AM – 5 PM`,
  },
];
}

export function getStaticPaths() {
	// Astro hoists getStaticPaths, so keep this slug list in sync with getTrainings().
	return [
		{ params: { slug: 'hattiesburg-ytt' } },
		{ params: { slug: 'training' } },
		{ params: { slug: '25-hr-hands-on-assisting' } },
	];
}

function processContent(content: string): string {
	if (!content) return '';
	if (content.includes('<p>') || content.includes('<strong>')) return content;
	return marked(content);
}

function formatDateRange(startDate: string, endDate: string): string {
	if (!startDate && !endDate) return '';
	if (!endDate) return new Date(startDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
	if (!startDate) return new Date(endDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

	const start = new Date(startDate);
	const end = new Date(endDate);
	const startMonth = start.toLocaleDateString('en-US', { month: 'short' });
	const startDay = start.getDate();
	const startYear = start.getFullYear();
	const endMonth = end.toLocaleDateString('en-US', { month: 'short' });
	const endDay = end.getDate();
	const endYear = end.getFullYear();

	if (startMonth === endMonth && startYear === endYear) return `${startMonth} ${startDay}-${endDay}, ${startYear}`;
	if (startYear === endYear) return `${startMonth} ${startDay} - ${endMonth} ${endDay}, ${startYear}`;
	return `${startMonth} ${startDay}, ${startYear} - ${endMonth} ${endDay}, ${endYear}`;
}

const baseTraining = getTrainings().find(t => t.slug === Astro.params.slug);
if (!baseTraining) throw new Error(`Missing training: ${Astro.params.slug}`);

const training = {
	...baseTraining,
	body: processContent(baseTraining.body),
	gallery: [],
	dateDisplay: formatDateRange(baseTraining.startDate, baseTraining.endDate),
};


// Check if training has passed
const isPastEvent = training.endDate && new Date(training.endDate) < new Date();
---

<Layout title={`${training.title} — Love More`}>
	<Navigation />

	<main id="main-content">
		<EventDetailHero
			title={training.title}
			subtitle={training.subtitle}
			image={training.headerImage}
			icon={GraduationCap}
			dateDisplay={training.dateDisplay}
		/>

		<EventDetailLayout
			title={training.title}
			subtitle={training.subtitle}
			image={training.flyerImage}
			body={training.body}
			gallery={training.gallery}
			startDate={training.startDate}
			endDate={training.endDate}
			isPastEvent={isPastEvent}
			ctaButtonLabel={training.ctaText}
			ctaButtonUrl={training.ctaLink}
			backLink="/trainings"
			backLinkText="View All Programs"
			price={training.price}
		/>
	</main>

	<Footer />
</Layout>
