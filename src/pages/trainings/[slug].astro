---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import EventDetailHero from '../../components/EventDetailHero.astro';
import EventDetailLayout from '../../components/EventDetailLayout.astro';
import { GraduationCap } from 'lucide-astro';
import { fetchAPI, getStrapiMedia } from '../../lib/strapi';
import { marked } from 'marked';

export async function getStaticPaths() {
	// Helper to handle both HTML and Markdown content
	function processContent(content: string): string {
		if (!content) return '';
		// If content contains HTML tags, return as-is
		if (content.includes('<p>') || content.includes('<strong>')) {
			return content;
		}
		// Otherwise treat as Markdown
		return marked(content);
	}

	try {
		const trainingsResponse = await fetchAPI<any>({
			endpoint: 'trainings',
			query: {
				// Fetch ALL trainings (past and future) to avoid 404s
				'populate': '*'
			},
			wrappedByKey: 'data'
		});

		if (!trainingsResponse || trainingsResponse.length === 0) {
			console.warn('No trainings found in Strapi - returning empty array');
			return [];
		}

		// Filter out trainings without slugs
		const validTrainings = trainingsResponse.filter((training: any) => training.slug);

		if (validTrainings.length === 0) {
			console.warn('No trainings with valid slugs found - returning empty array');
			return [];
		}

		return validTrainings.map((training: any) => ({
			params: { slug: training.slug },
			props: {
				training: {
					...training,
					image: training.image?.url ? getStrapiMedia(training.image.url) : null,
					body: processContent(training.body),
					gallery: training.gallery?.map((img: any) => ({
						url: getStrapiMedia(img.url),
						alternativeText: img.alternativeText || training.title
					})) || []
				}
			}
		}));
	} catch (error) {
		console.error('Error fetching trainings for static paths:', error);
		return [];
	}
}

const { training } = Astro.props;

// Check if training has passed
const isPastEvent = training.endDate && new Date(training.endDate) < new Date();

// Format dates for display
const formatDate = (date: string) => {
	return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};
const dateDisplay = training.startDate && training.endDate
	? `${formatDate(training.startDate)} - ${formatDate(training.endDate)}`
	: training.startDate
		? formatDate(training.startDate)
		: training.endDate
			? formatDate(training.endDate)
			: '';
---

<Layout title={`${training.title} — Love More`}>
	<Navigation />

	<main id="main-content">
		<EventDetailHero
			title={training.title}
			subtitle={training.subtitle}
			image={training.image}
			icon={GraduationCap}
			dateDisplay={dateDisplay}
		/>

		<EventDetailLayout
			title={training.title}
			subtitle={training.subtitle}
			image={training.image}
			body={training.body}
			gallery={training.gallery}
			startDate={training.startDate}
			endDate={training.endDate}
			isPastEvent={isPastEvent}
			ctaButtonLabel={training.ctaText}
			ctaButtonUrl={training.ctaLink}
			backLink="/trainings"
			backLinkText="View All Programs"
		/>
	</main>

	<Footer />
</Layout>
