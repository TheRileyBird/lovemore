---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
import { fetchAPI } from '../../lib/strapi';

export async function getStaticPaths() {
	try {
		const trainingsResponse = await fetchAPI<any>({
			endpoint: 'trainings',
			query: {
				'filters[active][$eq]': true
			},
			wrappedByKey: 'data'
		});

		if (!trainingsResponse || trainingsResponse.length === 0) {
			console.warn('No trainings found in Strapi - returning empty array');
			return [];
		}

		return trainingsResponse.map((training: any) => ({
			params: { slug: training.slug },
			props: { training }
		}));
	} catch (error) {
		console.error('Error fetching trainings for static paths:', error);
		return [];
	}
}

const { training } = Astro.props;
---

<Layout title={`${training.title} — Love More`}>
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="training-heading">
			<div class="absolute inset-0 z-0">
				<img
					src="https://images.squarespace-cdn.com/content/v1/59d53a9459cc683b30818a39/1698857393487-I0M9VNSSDU0WURO47UYG/IMG_5194.jpeg?format=1600w"
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
					style="object-position: 100% 40%;"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<h1 id="training-heading" class="text-4xl md:text-6xl font-display font-bold text-white tracking-wide mb-4">
					{training.title}
				</h1>
			</div>
		</section>

		<!-- Content Section -->
		<section class="py-20 bg-white">
			<div class="container mx-auto px-6">
				<div class="max-w-4xl mx-auto">
					<div class="prose prose-lg max-w-none text-neutral-700 leading-relaxed mb-12" set:html={training.body} />

					{training.certification && (
						<div class="bg-cream-50 p-6 rounded-xl border border-warm-gray-200 mb-8">
							<p class="text-sm font-semibold text-charcoal mb-1">Certification</p>
							<p class="text-neutral-600">{training.certification}</p>
						</div>
					)}

					{(training.startDate || training.endDate || training.price) && (
						<div class="bg-cream-50 p-6 rounded-xl border border-warm-gray-200 mb-8">
							<h3 class="text-xl font-semibold text-charcoal mb-4">Program Details</h3>
							<div class="space-y-2">
								{training.startDate && (
									<p class="text-neutral-600">
										<span class="font-semibold">Start Date:</span> {new Date(training.startDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
									</p>
								)}
								{training.endDate && (
									<p class="text-neutral-600">
										<span class="font-semibold">End Date:</span> {new Date(training.endDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
									</p>
								)}
								{training.price && (
									<p class="text-neutral-600">
										<span class="font-semibold">Investment:</span> ${training.price}
									</p>
								)}
							</div>
						</div>
					)}

					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<Button href={training.ctaLink || '/contact'} variant={training.variant || 'primary'} size="large">
							{training.ctaText || 'Request Information'}
						</Button>
						<a
							href="/trainings"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
						>
							View All Programs
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
