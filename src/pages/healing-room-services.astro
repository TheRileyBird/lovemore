---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Divider from '../components/Divider.astro';
import { ArrowRight, HeartHandshake } from 'lucide-astro';
import { marked } from 'marked';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import heroImage from '../assets/images/heart-kneel.jpg';
import compressionTherapyImage from '../assets/images/classes/compression-therapy.jpg';
import intuitiveGuidanceImage from '../assets/images/classes/intuitive-guidance-coaching.jpg';
import redLightTherapyImage from '../assets/images/classes/red-light-therapy.jpg';
import reikiImage from '../assets/images/classes/reiki.jpg';
import sriYantraSoundHealingImage from '../assets/images/classes/sri-yantra-sound-healing.jpg';

interface HealingRoomService {
	name: string;
	description: string;
	image: ImageMetadata;
}

function processContent(content: string): string {
	if (!content) return '';
	if (content.includes('<p>') || content.includes('<strong>')) return content;
	return marked(content);
}

const healingRoomServices: HealingRoomService[] = [
	{
		name: "Compression Therapy",
		description: `Through the compression pant sleeves and Hyperice compression system, this 20 minute recovery session is flushing the toxins and allowing new oxygen and blood into your lower extremities. With the lights drawn low, you are allowed to lay in comfort and extend your savassana practice an extra 10 or 20 minutes while getting amazing recovery benefits.`,
		image: compressionTherapyImage,
	},
	{
		name: "Reiki",
		description: `Reiki is a gentle, energy-based healing experience designed to promote relaxation, balance, and overall well-being. Reiki is often used to:
- Reduce stress and anxiety
- Support emotional release
- Improve sleep and relaxation
- Enhance overall energy flow
After a session, you may feel lighter, more grounded, or deeply calm. Some people also notice shifts in mood, clarity, or physical tension over the following days. It’s a subtle yet powerful practice that meets you exactly where you are—whether you’re seeking rest, healing, or simply a moment to reconnect with yourself.`,
		image: reikiImage,
	},
	{
		name: "Intuitive Guidance & Coaching",
		description: `This 90-minute 1:1 session is for moms, creators, entrepreneurs, or anyone feeling the pull toward a more aligned and intentional life. Together, we’ll explore what’s holding you back, clarify your next steps, and build practical tools you can use in your daily life.`,
		image: intuitiveGuidanceImage,
	},
	{
		name: "Red Light Therapy",
		description: `Red light sessions are 15 mins, red light blankets, which incorporate red light therapy, offer a variety of potential benefits, including muscle recovery, pain relief, improved skin health, and enhanced sleep. They work by exposing the body to specific wavelengths of light that can stimulate various cellular processes, promoting healing and overall well-being.`,
		image: redLightTherapyImage,
	},
	{
		name: "Sri Yantra Sound Healing",
		description: `This personalized session combines VoiceBio Voice Analysis, prescribed sound bath therapy, and Tuning Fork Therapy to support your healing journey. Using Cymatic Frequencies through Body Pod body speakers and the Sound Lounge Sound Bed (included in the first session), the therapy is designed to restore balance and well-being. Each private, 60-90 minute session equips you with resources and quidance to continue your on practice of healing.`,
		image: sriYantraSoundHealingImage,
	},
].map(service => ({ ...service, description: processContent(service.description) }));
---

<Layout title="Healing Room Services — Love More">
	<Navigation />

	<main id="main-content">
		<section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="healing-room-heading">
			<div class="absolute inset-0 z-0">
				<img
					src={heroImage.src}
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
					style="object-position: 50% 45%;"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<HeartHandshake class="w-16 h-16 text-brand mx-auto mb-6" aria-hidden="true" />
				<h1 id="healing-room-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide">
					Healing Room Services
				</h1>
			</div>
		</section>

		<section class="py-16 bg-cream" aria-labelledby="intro-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 id="intro-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
						Support for Restoration and Renewal
					</h2>
					<Divider width="short" class="mb-6" />
					<p class="text-lg text-neutral-600 leading-relaxed">
						Our healing room offers supportive services designed to help you regulate, recover, and reconnect. Explore modalities that complement your movement practice and create more space for balance in daily life.
					</p>
				</div>
			</div>
		</section>

		<section class="py-24 bg-white" aria-labelledby="services-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<h2 id="services-heading" class="text-4xl md:text-5xl font-display font-bold text-charcoal mb-4 tracking-wide text-center">
						Available Services
					</h2>
					<p class="text-center text-lg text-neutral-600 mb-16 max-w-3xl mx-auto">
						Each offering is presented with the same guided, welcoming approach you know from our classes, with a focus on care, nervous system support, and whole-person wellness.
					</p>

					{healingRoomServices.length === 0 ? (
						<div class="text-center py-12">
							<p class="text-lg text-neutral-600 mb-4">
								Healing room services will be listed here once they are published in the CMS.
							</p>
							<a
								href="/contact"
								class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-brand text-white hover:bg-charcoal hover:shadow-lg px-8 py-4 text-base"
							>
								Contact Us
							</a>
						</div>
					) : (
						<div class="flex flex-col gap-y-8">
							{healingRoomServices.map((service, index) => (
								<a
									href="/contact"
									class={`group grid grid-cols-1 overflow-clip rounded-[1.875rem] border border-neutral-200 bg-cream lg:grid-cols-2 lg:grid-rows-1 transition-all duration-500 hover:shadow-2xl ${index % 2 === 1 ? 'lg:grid-flow-dense' : ''}`}
								>
									<div class={`relative ${index % 2 === 1 ? 'lg:col-start-2' : ''}`}>
										<header class="flex items-center justify-center border-b border-neutral-200 px-8 py-6 lg:justify-start">
											<h3 class="text-xl font-bold text-charcoal text-center lg:text-left">
												{service.name}
											</h3>
										</header>
										<div class="flex flex-col place-items-start gap-y-6 p-10 pb-20">
											<div class="prose max-w-none text-neutral-600 leading-relaxed [&_p]:mb-4" set:html={service.description} />
										</div>
										<div class="absolute bottom-0 left-0 right-0 px-10 pb-6 translate-y-0 opacity-100 lg:translate-y-full lg:opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
											<span class="inline-flex items-center gap-2 py-3 text-brand font-bold tracking-wider uppercase text-sm">
												Learn More
												<ArrowRight class="w-4 h-4" aria-hidden="true" />
											</span>
										</div>
									</div>
									<div class={`relative select-none bg-neutral-50 h-full overflow-hidden ${index % 2 === 1 ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
										<Image
											src={service.image}
											alt={service.name}
											class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
											loading={index < 2 ? 'eager' : 'lazy'}
										/>
									</div>
								</a>
							))}
						</div>
					)}
				</div>
			</div>
		</section>

		<section class="py-20 bg-cream">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Ready to Book a Service?
					</h2>
					<p class="text-lg text-neutral-600 mb-8 leading-relaxed">
						Reach out with questions or connect with us to find the healing room service that fits your needs.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<Button href="/contact" variant="primary" size="large">
							Contact Us
						</Button>
						<a
							href="/schedule"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
						>
							View Schedule
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
