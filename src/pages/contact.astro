---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import {Facebook, Instagram, Mail} from 'lucide-astro';
import heroImage from '../assets/images/heart-kneel.jpg';
---

<Layout title="Contact — Love More">
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="contact-heading">
			<div class="absolute inset-0 z-0">
				<img
					src={heroImage.src}
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover object-top"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<Mail class="w-12 h-12 text-brand mx-auto mb-6" aria-hidden="true" />
				<h1 id="contact-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide">
					Get in Touch
				</h1>
			</div>
		</section>

		<!-- Contact Form Section -->
		<section class="py-24 bg-cream-50" aria-labelledby="form-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto">
					<div class="bg-white p-12 rounded-2xl shadow-md border border-warm-gray-200">
						<div class="text-center mb-10">

							<h2 id="form-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
								We're Here to Help
							</h2>
							<p class="text-lg text-neutral-600 mb-2">
								Whether you have a question, an idea, or just want to say hello, feel free to reach out—we're here to help.
							</p>
						</div>

						<form name="contact" method="POST" action="/thank-you" data-netlify="true" netlify-honeypot="bot-field" class="space-y-6">
							<input type="hidden" name="form-name" value="contact" />
							<p class="hidden" aria-hidden="true">
								<label>Don't fill this out if you're human: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
							</p>

							<div>
								<label for="name" class="block text-sm font-medium text-neutral-700 mb-2">Name</label>
								<input
									type="text"
									id="name"
									name="name"
									placeholder="Your name"
									required
									aria-required="true"
									class="w-full px-6 py-4 rounded-lg border border-warm-gray-200 focus:border-brand focus:ring-4 focus:ring-brand/20 outline-none transition-all"
								/>
							</div>

							<div>
								<label for="email" class="block text-sm font-medium text-neutral-700 mb-2">Email</label>
								<input
									type="email"
									id="email"
									name="email"
									placeholder="Your email address"
									required
									aria-required="true"
									class="w-full px-6 py-4 rounded-lg border border-warm-gray-200 focus:border-brand focus:ring-4 focus:ring-brand/20 outline-none transition-all"
								/>
							</div>

							<div>
								<label for="phone" class="block text-sm font-medium text-neutral-700 mb-2">Phone (optional)</label>
								<input
									type="tel"
									id="phone"
									name="phone"
									placeholder="Your phone number"
									class="w-full px-6 py-4 rounded-lg border border-warm-gray-200 focus:border-brand focus:ring-4 focus:ring-brand/20 outline-none transition-all"
								/>
							</div>

							<div>
								<label for="message" class="block text-sm font-medium text-neutral-700 mb-2">Message</label>
								<textarea
									id="message"
									name="message"
									rows="6"
									placeholder="Tell us what's on your mind..."
									required
									aria-required="true"
									class="w-full px-6 py-4 rounded-lg border border-warm-gray-200 focus:border-brand focus:ring-4 focus:ring-brand/20 outline-none transition-all resize-none"
								></textarea>
							</div>

							<Button type="submit" class="w-full">
								Send Message
							</Button>
						</form>

						<p class="text-sm text-neutral-500 text-center mt-8">
							We respect your privacy. We will never share your information.
						</p>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
