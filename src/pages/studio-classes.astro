---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import { Flame, Snowflake, ArrowRight } from 'lucide-astro';
import { fetchAPI, getStrapiMedia } from '../lib/strapi';

// Fetch all classes from Strapi
const classesResponse = await fetchAPI<any>({
	endpoint: 'classes',
	query: {
		'populate': 'image',
		'sort': 'order:asc'
	},
	wrappedByKey: 'data'
});

// Separate classes by type
const heatedClassData = classesResponse
	.filter((classItem: any) => classItem.type === 'heated')
	.map((classItem: any) => ({
		name: classItem.name,
		temperature: classItem.temperature,
		description: classItem.description,
		image: classItem.image?.url ? getStrapiMedia(classItem.image.url) : null
	}));

const nonHeatedClassData = classesResponse
	.filter((classItem: any) => classItem.type === 'non-heated')
	.map((classItem: any) => ({
		name: classItem.name,
		description: classItem.description,
		image: classItem.image?.url ? getStrapiMedia(classItem.image.url) : null
	}));
---

<Layout title="Class Descriptions — Love More">
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="classes-heading">
			<div class="absolute inset-0 z-0">
				<img
					src="https://images.squarespace-cdn.com/content/v1/59d53a9459cc683b30818a39/1698857393487-I0M9VNSSDU0WURO47UYG/IMG_5194.jpeg?format=1600w"
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
					style="object-position: 100% 40%;"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<h1 id="classes-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide">
					Our Classes
				</h1>
			</div>
		</section>

		<!-- Intro Section -->
		<section class="py-20 bg-cream" aria-labelledby="intro-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-4xl mx-auto text-center">
					<h2 id="intro-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Movement for Your Mind, Body, and Spirit
					</h2>
					<p class="text-lg text-neutral-600 leading-relaxed mb-8">
						Our studio is dedicated to providing holistic and enriching movement experiences that nurture the mind, body, and spirit. With a diverse range of classes led by experienced instructors, we invite you to explore the myriad paths of yoga, sculpting, and dance each tailored to meet your unique journey. Whether you're a seasoned yogi or just beginning to explore moving your body in new ways, our classes are designed to guide you toward a deeper connection with yourself, fostering self-love, mindfulness, and inner harmony. Step onto your mat and embark on a voyage of self-discovery and growth.
					</p>

					<!-- Class Category Navigation -->
					<div class="flex flex-col sm:flex-row gap-4 justify-center mt-12">
						<a
							href="#heated-classes"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-charcoal text-white hover:bg-brand hover:shadow-lg px-8 py-4 text-base"
						>
							Heated Classes
						</a>
						<a
							href="#non-heated-classes"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-charcoal text-white hover:bg-brand hover:shadow-lg px-8 py-4 text-base"
						>
							Non-Heated Classes
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Heated Classes Section -->
		<section id="heated-classes" class="py-20 bg-white" aria-labelledby="heated-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<h2 id="heated-heading" class="text-4xl md:text-5xl font-display font-bold text-charcoal mb-4 tracking-wide text-center">
						Heated Classes
					</h2>
					<p class="text-center text-lg text-neutral-600 mb-16 max-w-3xl mx-auto">
						Experience the many benefits of heat. Our heated classes maximize your flow, increase oxygen levels, and improve the mind-body connection.
					</p>

					<div class="flex flex-col gap-y-8">
						{heatedClassData.map((classItem, index) => (
							<a
								href="/schedule"
								class={`group grid grid-cols-1 overflow-clip rounded-[1.875rem] border border-neutral-200 bg-cream lg:grid-cols-2 lg:grid-rows-1 transition-all duration-500 hover:shadow-2xl ${index % 2 === 1 ? 'lg:grid-flow-dense' : ''}`}
							>
								<div class={`relative ${index % 2 === 1 ? 'lg:col-start-2' : ''}`}>
									<header class="flex items-center justify-between gap-x-4 border-b border-neutral-200 px-8 py-6">
										<h3 class="text-xl font-bold text-charcoal">
											{classItem.name}
										</h3>
										<span class="inline-flex items-center gap-1 px-3 py-1 bg-white rounded-full border border-neutral-200 text-sm shrink-0">
											<Flame class="w-4 h-4 text-brand" aria-hidden="true" />
											{classItem.temperature}
										</span>
									</header>
									<div class="flex flex-col place-items-start gap-y-6 p-10 pb-20">
										<p class="text-neutral-600 leading-relaxed">
											{classItem.description}
										</p>
									</div>
									<div class="absolute bottom-0 left-0 right-0 px-10 pb-6 translate-y-0 opacity-100 lg:translate-y-full lg:opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
										<span class="inline-flex items-center gap-2 py-3 text-brand font-bold tracking-wider uppercase text-sm">
											Book Now
											<ArrowRight class="w-4 h-4" aria-hidden="true" />
										</span>
									</div>
								</div>
								<div class={`relative select-none bg-neutral-50 h-full overflow-hidden ${index % 2 === 1 ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
									<img
										src={classItem.image}
										alt=""
										class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
									/>
								</div>
							</a>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Non-Heated Classes Section -->
		<section id="non-heated-classes" class="py-20 bg-cream" aria-labelledby="nonheated-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<h2 id="nonheated-heading" class="text-4xl md:text-5xl font-display font-bold text-charcoal mb-4 tracking-wide text-center">
						Non-Heated Classes
					</h2>
					<p class="text-center text-lg text-neutral-600 mb-16 max-w-3xl mx-auto">
						Gentle, restorative practices that promote relaxation, flexibility, and mindfulness without the added heat.
					</p>

					<div class="flex flex-col gap-y-8">
						{nonHeatedClassData.map((classItem, index) => (
							<a
								href="/schedule"
								class={`group grid grid-cols-1 overflow-clip rounded-[1.875rem] border border-neutral-200 bg-white lg:grid-cols-2 lg:grid-rows-1 transition-all duration-500 hover:shadow-2xl ${index % 2 === 1 ? 'lg:grid-flow-dense' : ''}`}
							>
								<div class={`relative ${index % 2 === 1 ? 'lg:col-start-2' : ''}`}>
									<header class="flex items-center justify-between gap-x-4 border-b border-neutral-200 px-8 py-6">
										<h3 class="text-xl font-bold text-charcoal">
											{classItem.name}
										</h3>
										<span class="inline-flex items-center gap-1 px-3 py-1 bg-cream rounded-full border border-neutral-200 text-sm shrink-0">
											<Snowflake class="w-4 h-4 text-blue-500" aria-hidden="true" />
											Room Temperature
										</span>
									</header>
									<div class="flex flex-col place-items-start gap-y-6 p-10 pb-20">
										<p class="text-neutral-600 leading-relaxed">
											{classItem.description}
										</p>
									</div>
									<div class="absolute bottom-0 left-0 right-0 px-10 pb-6 translate-y-0 opacity-100 lg:translate-y-full lg:opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
										<span class="inline-flex items-center gap-2 px-6 py-3 text-brand font-bold tracking-wider uppercase text-sm">
											Book Now
											<ArrowRight class="w-4 h-4" aria-hidden="true" />
										</span>
									</div>
								</div>
								<div class={`relative select-none bg-neutral-50 h-full overflow-hidden ${index % 2 === 1 ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
									<img
										src={classItem.image}
										alt=""
										class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
									/>
								</div>
							</a>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Call to Action -->
		<section class="py-20 bg-cream">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Ready to Begin?
					</h2>
					<p class="text-lg text-neutral-600 mb-8 leading-relaxed">
						New to Love More? Start with our 3-week intro pass and discover the practice that's right for you.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<Button href="/start" variant="primary" size="large">
							3 Week Intro — $56
						</Button>
						<a
							href="/schedule"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
						>
							View Schedule
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
