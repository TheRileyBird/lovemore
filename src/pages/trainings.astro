---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Divider from '../components/Divider.astro';
import EventCard from '../components/EventCard.astro';
import { marked } from 'marked';
import heroImage from '../assets/images/halfmoon.jpg';
import type { ImageMetadata } from 'astro';

interface Training {
	title: string;
	subtitle: string | null;
	slug: string;
	startDate: string;
	endDate: string;
	price: number | null;
	flyerImage: ImageMetadata | null;
	headerImage: ImageMetadata | null;
	ctaText: string | null;
	ctaLink: string | null;
	body: string;
}

const trainingImages = import.meta.glob('../assets/images/trainings/*.{jpg,jpeg,png,webp}', { eager: true, import: 'default' }) as Record<string, ImageMetadata>;

function getTrainingImage(path: string): ImageMetadata {
	const image = trainingImages[path];
	if (!image) throw new Error(`Missing training image: ${path}`);
	return image;
}

const trainings: Training[] = [
  {
    title: "200+ RYT Yoga Teacher Training with ayurveda philosophy & asanas",
    subtitle: null,
    slug: "training",
    startDate: "2026-05-15",
    endDate: "2026-07-12",
    price: null,
    flyerImage: getTrainingImage("../assets/images/trainings/training.jpg"),
    headerImage: getTrainingImage("../assets/images/trainings/training-header.jpg"),
    ctaText: "Learn More",
    ctaLink: "/contact",
    body: `Step Into the Journey of A Lifetime. . .a deeper understanding to your yoga practice and your own personal self.

This training is through Love More University and held at Love More studio in beautiful downtown Covington, LA.

Get Certified in 8 Weekends!

Dates for the 2026 session are:

February 20th-22nd

March 6th-8th, 27th-29th

April 10th-12th, 24th-26th** (Ayurveda Weekend)

May 15th-17th

June 5th-7th, 26th-28th

July 10th-12th** (Graduation Weekend)

Fridays from 5p-9pm
Saturdays from 8a-8pm
Sundays from 8a-4pm

This 200+ hour yoga teacher training is designed to take your personal practice and understanding of yoga to a whole new level and provide you with the skillset to offer students an intelligent, dynamic and inspiring yoga class. The course is ideal for serious students and aspiring teachers. With thousands of hours of teaching experience, this teacher training program will provide an in-depth exploration into the practice, process and science of yoga.

The day consists of lecture time, meditation, posture clinics, self study, practice teaching and asana practice. Topics covered include: Detailed, alignment-based posture clinics, Multiple methods of sequencing a Vinyasa class, Meditation, Philosophy of yoga, Physical and energetic anatomy, Heat management, Daily physical practice.

**This includes an added 25 hour module of Ayurveda training where you will gain deep insights into Ayurvedic philosophy and principles, including doshas and lifestyle, empowering you to integrate this ancient wisdom into your own wellbeing and teaching practice. (If you are unable to attend this weekend, you are able to make it up during the next session offered.)

This training is designed to adequately prepare you to teach a dynamic and inspiring vinyasa yoga class.

You will have a vinyasa sequence that you are prepared to deliver in a safe and professional manner as well as be able to modify or intensify this sequence depending on your audience.

You will have the information to build your own sequences, understanding the how and why in creating a class.

You will understand yourself better and have a more informed personal practice.

You will have completed all of the requirements of a Yoga Alliance Recognized Teacher Training program and be qualified to request registration with Yoga Alliance.`,
  },
  {
    title: "Yoga Sculpt Training",
    subtitle: null,
    slug: "yoga-sculpt-training",
    startDate: "2026-06-12",
    endDate: "2026-06-14",
    price: 495,
    flyerImage: getTrainingImage("../assets/images/trainings/yoga-sculpt-training.jpg"),
    headerImage: getTrainingImage("../assets/images/trainings/yoga-sculpt-training.jpg"),
    ctaText: "Sign Up!",
    ctaLink: "https://www.wellnessliving.com/rs/catalog-view.html?k_business=288067&id_sale=3&k_id=939591",
    body: `3 DAY TRAINING EXPERIENCE (for 200hr + yoga instructors and certified group fitness instructors with yoga experience)
Led by Jacqueline Hurst

Friday - 4pm- 8:30pm
Saturday - 8am - 8pm
Sunday - 8am - 4pm

Yoga Sculpt is the perfect mix between mindfulness, intentional movement, and fun! It’s a vinyasa-based style class with light weights included in the flow. Set to an upbeat playlist, you’re sure to have fun, sweat, and feel confident in yourself!
In this Continuing Education Training - You’ll learn how to safely and effectively combine yoga+mindfulness with strength training, cardio, and music for a dynamic and well-rounded class. This is for 200+ hour certified yoga teachers and certified group fitness instructors with yoga experience who are looking to add another format to their skillset.

From learning strength training, sequencing, musicality, and safety, this training will cover all aspects of introducing an engaging yoga sculpt class to your community. This 3-day experience (25 hours) will be led by nationally renowned yoga sculpt instructor, Jacqueline Hurst who has taught over 2000+ classes - from Texas to Louisiana to virtual.

Have questions? Please email Jax at theinvitationbyjax@gmail.com or send her a text at 504-908-5736.`,
  },
  {
    title: "25-hr Advanced",
    subtitle: null,
    slug: "25-hr-advanced",
    startDate: "2026-07-24",
    endDate: "2026-07-26",
    price: 400,
    flyerImage: getTrainingImage("../assets/images/trainings/25-hr-advanced.jpg"),
    headerImage: getTrainingImage("../assets/images/trainings/25-hr-advanced-header.jpg"),
    ctaText: "Sign Up Here!",
    ctaLink: "https://hotasanastudio.com/teacher-training/25-hours-advanced-patterning-creative-sequencing-at-love-more-hot-yoga",
    body: `## Reignite your creativity and transform the way you build and deliver your classes.

In this 25-hour training, you’ll dive into the art of creative sequencing—learning how to plan and adapt Vinyasa flows that are intentional, fluid, and deeply connected. Discover how to weave rhythm, structure, and energetic balance into your sequences so each class feels both inspired and purposeful.

Through hands-on practice, discussion, and exploration, you’ll develop a stronger understanding of how to move from simple progressions to more complex patterns, empowering you to teach dynamic yet inclusive classes that meet students where they are. Leave feeling confident in your ability to design classes that truly flow—from the first breath to the final rest.

### Times:
- Friday 5pm-9pm
- Saturday 8am-8pm
- Sunday 8am-5pm`,
  },
  {
    title: "25-hr Hands-on Assisting",
    subtitle: null,
    slug: "25-hr-hands-on-assisting",
    startDate: "2026-08-28",
    endDate: "2026-08-30",
    price: 400,
    flyerImage: getTrainingImage("../assets/images/trainings/25-hr-hands-on-assisting.jpg"),
    headerImage: getTrainingImage("../assets/images/trainings/25-hr-hands-on-assisting-header.jpg"),
    ctaText: "Learn More",
    ctaLink: "https://hotasanastudio.com/teacher-training/25-hours-hands-on-assisting-love-more-covington-la",
    body: `## Deepen your teaching from the inside out.

This 25-hour training is dedicated to the art and skill of hands-on assists—helping you cultivate presence, refine your touch, and create safe, empowering adjustments in every class. You’ll explore anatomical and energetic alignment, practice assists for common postures, and learn how to use touch as a tool for guidance and support rather than correction.

Led by JoEllen Luke and Teresa Cantrelle, this immersive experience will help you strengthen your intuition, sharpen your observation skills, and grow your confidence in offering hands-on support. Expect a weekend filled with learning, feedback, and connection that will elevate both your teaching and your students’ experience.

### Dates:
- August 28-30, 2026

### Times:
- Fridays: 5 AM – 9 PM
- Saturdays: 8 AM – 8 PM
- Sundays: 8 AM – 5 PM`,
  },
];


function processContent(content: string): string {
	if (!content) return '';
	if (content.includes('<p>') || content.includes('<strong>')) return content;
	return marked(content);
}

const now = new Date();
const currentTrainings = trainings
	.filter(t => t.slug && (!t.endDate || new Date(t.endDate) >= now))
	.map(t => ({ ...t, body: processContent(t.body) }));
---

<Layout title="Teacher Training & Workshops — Love More">
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="trainings-heading">
			<div class="absolute inset-0 z-0">
				<img
					src={heroImage.src}
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
					style="object-position: 100% 40%;"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<h1 id="trainings-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide mb-4">
					Teacher Training & Workshops
				</h1>
				<p class="text-2xl text-white/95 max-w-3xl mx-auto font-light">
					Deepen Your Practice, Transform Your Teaching
				</p>
			</div>
		</section>

		<!-- Intro Section -->
		<section class="py-20 bg-cream" aria-labelledby="intro-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-4xl mx-auto text-center">
					<h2 id="intro-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
						Become a Certified Yoga Teacher
					</h2>
					<Divider width="short" class="mb-8" />
					<p class="text-lg text-neutral-600 leading-relaxed mb-6">
						Whether you're looking to deepen your personal practice or embark on a journey to share yoga with others, our teacher training programs provide comprehensive education, hands-on experience, and mentorship from experienced instructors. Our programs are registered with Yoga Alliance and taught by experienced E-RYT® certified instructors who are passionate about supporting the next generation of yoga teachers.
					</p>
				</div>
			</div>
		</section>

		<!-- Programs Section -->
		<section class="py-24 bg-white" aria-labelledby="programs-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<h2 id="programs-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-12 text-center tracking-wide">
						Training Programs
					</h2>

					{currentTrainings.length > 0 ? (
						<div class="flex flex-col gap-y-8">
							{currentTrainings.map((training: any, index: number) => (
								<EventCard
									title={training.title}
									subtitle={training.subtitle}
									slug={training.slug}
									flyerImage={training.flyerImage}
									body={training.body}
									startDate={training.startDate}
									endDate={training.endDate}
									price={training.price}
									index={index}
									basePath="/trainings"
								/>
							))}
						</div>
					) : (
						<div class="text-center py-16">
							<p class="text-2xl font-display text-charcoal mb-3">The next training is being cultivated.</p>
							<p class="text-lg text-neutral-600 mb-8">Your path to teaching unfolds in its own time — come back soon to take the next step.</p>
							<a
								href="/contact"
								class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
							>
								Get Notified
							</a>
						</div>
					)}
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-20 bg-white">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Ready to Begin Your Teaching Journey?
					</h2>
					<p class="text-lg text-neutral-600 mb-8 leading-relaxed">
						Contact us to learn more about upcoming training dates, tuition, and enrollment. We're here to answer all your questions and help you take the next step.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<Button href="/contact" variant="primary" size="large">
							Request Information
						</Button>
						<a
							href="/schedule"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
						>
							View Class Schedule
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
