---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Divider from '../components/Divider.astro';
import { Calendar, ArrowRight } from 'lucide-astro';
import { fetchAPI, getStrapiMedia } from '../lib/strapi';
import { marked } from 'marked';

// Helper to handle both HTML and Markdown content
function processContent(content: string): string {
	if (!content) return '';
	// If content contains HTML tags, return as-is
	if (content.includes('<p>') || content.includes('<strong>')) {
		return content;
	}
	// Otherwise treat as Markdown
	return marked(content);
}

// Helper to strip HTML tags for plain text display
function stripHtml(html: string): string {
	if (!html) return '';
	return html.replace(/<[^>]*>/g, '').replace(/&[^;]+;/g, (entity) => {
		const entities: Record<string, string> = {
			'&amp;': '&',
			'&lt;': '<',
			'&gt;': '>',
			'&quot;': '"',
			'&#39;': "'"
		};
		return entities[entity] || entity;
	});
}

// Helper to format date ranges intelligently
function formatDateRange(startDate: string, endDate: string): string {
	if (!startDate && !endDate) return '';
	if (!endDate) return new Date(startDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
	if (!startDate) return new Date(endDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

	const start = new Date(startDate);
	const end = new Date(endDate);

	const startMonth = start.toLocaleDateString('en-US', { month: 'short' });
	const startDay = start.getDate();
	const startYear = start.getFullYear();

	const endMonth = end.toLocaleDateString('en-US', { month: 'short' });
	const endDay = end.getDate();
	const endYear = end.getFullYear();

	// Same month and year: "May 21-23, 2026"
	if (startMonth === endMonth && startYear === endYear) {
		return `${startMonth} ${startDay}-${endDay}, ${startYear}`;
	}

	// Same year, different months: "May 21 - Jun 3, 2026"
	if (startYear === endYear) {
		return `${startMonth} ${startDay} - ${endMonth} ${endDay}, ${startYear}`;
	}

	// Different years: "Dec 21, 2025 - Jan 3, 2026"
	return `${startMonth} ${startDay}, ${startYear} - ${endMonth} ${endDay}, ${endYear}`;
}

// Fetch trainings from Strapi
const trainingsResponse = await fetchAPI<any>({
	endpoint: 'trainings',
	query: {
		sort: 'startDate:asc',
		'filters[active][$eq]': true,
		'populate': 'image'
	},
	wrappedByKey: 'data'
});

// Filter for upcoming trainings only (not past events)
const now = new Date();
const trainings = trainingsResponse
	?.filter((training: any) => {
		// Must have a slug
		if (!training.slug) return false;
		// If no endDate, show it (assume upcoming)
		if (!training.endDate) return true;
		// Only show if endDate is in the future
		return new Date(training.endDate) >= now;
	})
	.map((training: any) => ({
		title: training.title,
		subtitle: training.subtitle,
		slug: training.slug,
		image: training.image?.url ? getStrapiMedia(training.image.url) : null,
		body: stripHtml(training.body),
		startDate: training.startDate,
		endDate: training.endDate
	})) || [];
---

<Layout title="Teacher Training & Workshops — Love More">
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="trainings-heading">
			<div class="absolute inset-0 z-0">
				<img
					src="https://images.squarespace-cdn.com/content/v1/59d53a9459cc683b30818a39/1698857393487-I0M9VNSSDU0WURO47UYG/IMG_5194.jpeg?format=1600w"
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
					style="object-position: 100% 40%;"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<h1 id="trainings-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide mb-4">
					Teacher Training & Workshops
				</h1>
				<p class="text-2xl text-white/95 max-w-3xl mx-auto font-light">
					Deepen Your Practice, Transform Your Teaching
				</p>
			</div>
		</section>

		<!-- Intro Section -->
		<section class="py-20 bg-cream" aria-labelledby="intro-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-4xl mx-auto text-center">
					<h2 id="intro-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
						Become a Certified Yoga Teacher
					</h2>
					<Divider width="short" class="mb-8" />
					<p class="text-lg text-neutral-600 leading-relaxed mb-6">
						Whether you're looking to deepen your personal practice or embark on a journey to share yoga with others, our teacher training programs provide comprehensive education, hands-on experience, and mentorship from experienced instructors.
					</p>
					<p class="text-lg text-neutral-600 leading-relaxed">
						Our programs are registered with Yoga Alliance and taught by experienced E-RYT® certified instructors who are passionate about supporting the next generation of yoga teachers.
					</p>
				</div>
			</div>
		</section>

		<!-- Programs Section -->
		<section class="py-24 bg-white" aria-labelledby="programs-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<h2 id="programs-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-12 text-center tracking-wide">
						Training Programs
					</h2>

					<div class="flex flex-col gap-y-8">
						{trainings.map((training: any, index: number) => {
							const dateDisplay = formatDateRange(training.startDate, training.endDate);

							return (
								<a
									href={`/trainings/${training.slug}`}
									class={`group grid grid-cols-1 overflow-clip rounded-[1.875rem] border border-neutral-200 bg-cream lg:grid-cols-2 lg:grid-rows-1 transition-all duration-500 hover:shadow-2xl ${index % 2 === 1 ? 'lg:grid-flow-dense' : ''}`}
								>
									<div class={`relative ${index % 2 === 1 ? 'lg:col-start-2' : ''}`}>
										<header class="flex flex-nowrap items-center justify-between gap-x-4 border-b border-neutral-200 px-8 py-6">
											<h3 class="text-xl font-bold text-charcoal">
												{training.title}
											</h3>
											{dateDisplay && (
												<span class="inline-flex items-center gap-1 px-3 py-1 bg-cream rounded-full border border-neutral-200 text-sm shrink-0">
													<Calendar class="w-4 h-4 text-brand" aria-hidden="true" />
													{dateDisplay}
												</span>
											)}
										</header>
										<div class="p-10 pb-20">
											{training.subtitle && (
												<p class="text-lg text-neutral-600 font-medium mb-3">{training.subtitle}</p>
											)}
											<div class="prose line-clamp-6 max-w-none text-neutral-600 leading-relaxed [&_p]:mb-4">{training.body}</div>
										</div>
										<div class="absolute bottom-0 left-0 right-0 px-10 pb-6 translate-y-0 opacity-100 lg:translate-y-full lg:opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
											<span class="inline-flex items-center gap-2 py-3 text-brand font-bold tracking-wider uppercase text-sm">
												Learn More
												<ArrowRight class="w-4 h-4" aria-hidden="true" />
											</span>
										</div>
									</div>
									<div class={`relative select-none bg-neutral-50 h-full min-h-[300px] overflow-hidden ${index % 2 === 1 ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
										<img
											src={training.image || 'https://images.unsplash.com/photo-1537953773345-d172ccf13cf1?w=1200&auto=format&fit=crop&q=80'}
											alt={training.title}
											class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-110"
										/>
									</div>
								</a>
							);
						})}
					</div>
				</div>
			</div>
		</section>

		<!-- Why Choose Us Section -->
		<section class="py-20 bg-cream">
			<div class="container mx-auto px-6">
				<div class="max-w-4xl mx-auto">
					<h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-12 text-center tracking-wide">
						Why Train With Us?
					</h2>

					<div class="grid md:grid-cols-2 gap-8">
						<div class="bg-white p-6 rounded-xl">
							<h3 class="text-xl font-semibold text-charcoal mb-3">Experienced Faculty</h3>
							<p class="text-neutral-600 leading-relaxed">
								Learn from E-RYT® 500 certified teachers with years of teaching and training experience.
							</p>
						</div>

						<div class="bg-white p-6 rounded-xl">
							<h3 class="text-xl font-semibold text-charcoal mb-3">Small Class Sizes</h3>
							<p class="text-neutral-600 leading-relaxed">
								Benefit from personalized attention and mentorship in intimate training groups.
							</p>
						</div>

						<div class="bg-white p-6 rounded-xl">
							<h3 class="text-xl font-semibold text-charcoal mb-3">Comprehensive Curriculum</h3>
							<p class="text-neutral-600 leading-relaxed">
								Our programs exceed Yoga Alliance standards with additional hours of study and practice.
							</p>
						</div>

						<div class="bg-white p-6 rounded-xl">
							<h3 class="text-xl font-semibold text-charcoal mb-3">Community Support</h3>
							<p class="text-neutral-600 leading-relaxed">
								Join a supportive community of teachers and continue learning through our ongoing education programs.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-20 bg-white">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Ready to Begin Your Teaching Journey?
					</h2>
					<p class="text-lg text-neutral-600 mb-8 leading-relaxed">
						Contact us to learn more about upcoming training dates, tuition, and enrollment. We're here to answer all your questions and help you take the next step.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<Button href="/contact" variant="primary" size="large">
							Request Information
						</Button>
						<a
							href="/schedule"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
						>
							View Class Schedule
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
