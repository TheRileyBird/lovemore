---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Divider from '../components/Divider.astro';
import { Heart, Users, Sparkles, Home } from 'lucide-astro';
import heroImage from '../assets/images/porch.jpeg';
import membershipUnlimited from '../assets/images/group.jpg';
import membershipMini from '../assets/images/warrior2.jpg';
import membershipPack from '../assets/images/downdog.jpg';

const memberships = [
	{
		name: 'COMMUNITY UNLIMITED',
		url: 'https://www.wellnessliving.com/rs/catalog-view.html?k_business=288067&id_sale=1&k_id=4035293',
		buttonLabel: '$149/mo',
		icon: Users,
		features: [
			'Unlimited in studio & online classes',
			'15% off mats and LM items',
			'Free mat, towel, and water fills',
			'Free mat storage',
			'1 Buddy Pass per month',
			'$10 off 1 specialty class per month',
			'1 Healing service per month (Red light or compression therapy)',
			'10% off Reiki sessions',
			'$200 off retreats and YTT'
		],
		image: membershipUnlimited.src
	},
	{
		name: 'MOVEMENT MINI',
		url: 'https://www.wellnessliving.com/rs/catalog-view.html?k_business=288067&id_sale=1&k_id=4035277',
		buttonLabel: '$92/mo',
		icon: Heart,
		features: [
			'4 classes per month',
			'15% off apparel and LM items',
			'$5 off healing services'
		],
		image: membershipMini.src
	},
	{
		name: '5 CLASS PACK',
		url: 'https://www.wellnessliving.com/rs/catalog-view.html?k_business=288067&id_sale=1&k_id=4035299',
		buttonLabel: '$130',
		icon: Sparkles,
		features: [
			'5 classes included',
			'3 month expiration'
		],
		image: membershipPack.src
	}
];
---

<Layout title="Pricing Options — Love More">
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="pricing-heading">
			<div class="absolute inset-0 z-0">
				<img
					src={heroImage.src}
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
					style="object-position: 100% 40%;"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<h1 id="pricing-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide mb-4">
					Pricing Options
				</h1>
			</div>
		</section>

		<!-- Intro Section -->
		<section class="py-16 bg-cream" aria-labelledby="intro-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 id="intro-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
						Find the Right Membership For You
					</h2>
					<Divider width="short" class="mb-6" />
					<p class="text-lg text-neutral-600 leading-relaxed">
						Choose the membership that fits your lifestyle and goals. From occasional practice to daily commitment, we have options designed to support your journey.
					</p>
				</div>
			</div>
		</section>

		<!-- Membership Cards -->
		<section class="py-24 bg-white" aria-labelledby="memberships-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<h2 id="memberships-heading" class="sr-only">Membership Options</h2>

					<div class="space-y-12">
						{memberships.map((membership) => {
							const Icon = membership.icon;
							return (
								<div class="bg-cream-50 rounded-3xl overflow-hidden shadow-lg border border-warm-gray-200">
									<div class="grid md:grid-cols-5 gap-0">
										<div class="md:col-span-2 relative h-64 md:h-auto">
											<img
												src={membership.image}
												alt=""
												loading="lazy"
												class="absolute inset-0 w-full h-full object-cover"
											/>
										</div>

										<div class="md:col-span-3 p-8 md:p-10">
											<div class="flex items-center gap-3 mb-6">
												<Icon class="w-8 h-8 text-brand" aria-hidden="true" />
												<h3 class="text-2xl md:text-3xl font-display font-bold text-charcoal tracking-wide">
													{membership.name}
												</h3>
											</div>

											<h4 class="text-lg font-semibold text-charcoal mb-4">Includes:</h4>
											<ul class="space-y-2 mb-8">
												{membership.features.map((feature) => (
													<li class="flex items-start gap-3">
														<span class="text-brand mt-1">•</span>
														<span class="text-neutral-600">{feature}</span>
													</li>
												))}
											</ul>

											<Button href={membership.url} variant="primary" external={true}>
												{membership.buttonLabel}
											</Button>
										</div>
									</div>
								</div>
							);
						})}
					</div>
				</div>
			</div>
		</section>

		<!-- Call to Action -->
		<section class="pb-20 bg-white">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Ready to Join?
					</h2>
					<p class="text-lg text-neutral-600 mb-8 leading-relaxed">
						Have questions about which membership is right for you? Get in touch with us and we'll help you find the perfect fit.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<Button href="/start" variant="primary" size="large">
							Get Started for $56
						</Button>
						<a
							href="https://www.wellnessliving.com/rs/catalog-view.html?k_business=288067&id_sale=1&k_id=4035334"
							target="_blank"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
						>
							Drop-in for $28
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
