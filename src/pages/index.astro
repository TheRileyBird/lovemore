---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import StepCard from '../components/StepCard.astro';
import PillarCard from '../components/PillarCard.astro';
import TeamMemberCard from '../components/TeamMemberCard.astro';
import TeamMemberModal from '../components/TeamMemberModal.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Divider from '../components/Divider.astro';
import { Heart, Calendar, Users, Sparkles, Mail, ArrowRight } from 'lucide-astro';
import { fetchAPI, getStrapiMedia } from '../lib/strapi';
import { marked } from 'marked';
import aboutImage from '../assets/images/group2.jpg';
import pillar1Image from '../assets/images/warrior1.jpg';
import pillar2Image from '../assets/images/group3.jpg';
import pillar3Image from '../assets/images/heart-kneel.jpg';
import heroFallbackImage from '../assets/images/downdog.jpg';

// Helper to handle both HTML and Markdown content
function processContent(content: string): string {
	if (!content) return '';
	// If content contains HTML tags, return as-is
	if (content.includes('<p>') || content.includes('<strong>')) {
		return content;
	}
	// Otherwise treat as Markdown
	return marked(content);
}

// Fetch all team members from Strapi and filter for featured teachers
const teamMembersResponse = await fetchAPI<any>({
	endpoint: 'team-members',
	query: {
		'populate': '*'
	},
	wrappedByKey: 'data'
});

// Since this is in the frontmatter (the --- section) of an Astro file, the console output will appear in your terminal when Astro builds or runs the development server, not in the browser console.
// console.log(teamMembersResponse);

// Featured teacher IDs: JoEllen Luke (65), Dom Luke (46), Teresa (47)
const featuredTeacherIds = [65, 46, 47];

// Filter and sort by the order we want them displayed
const teamMembers = featuredTeacherIds
	.map(id => teamMembersResponse?.find((member: any) => member.id === id))
	.filter(Boolean)
	.map((member: any) => ({
		name: member?.name,
		title: member?.title,
		image: member?.image?.url ? getStrapiMedia(member.image.url) : null,
		bio: processContent(member?.bio),
		socialLink: member?.socialLink || null
	}));

const steps = [
	{ number: 1, title: 'Buy Your 3 Week Intro Pass', description: 'Purchase your intro pass online or in person' },
	{ number: 2, title: 'Show Up 15 Minutes Early', description: 'Arrive early to get settled and meet your instructors' },
	{ number: 3, title: 'Feel The Love & Try Your Best', description: 'Connect with our welcoming community and begin your transformation' }
];

const pillars = [
	{
		icon: Heart,
		title: 'Movement',
		description: 'Meet us on the mat to unlock your inner strength and zen. Embark on the personal journey of connecting your mind, body, and spirit through movement.',
		link: '/movement',
		image: pillar1Image.src
	},
	{
		icon: Users,
		title: 'Community',
		description: 'Here is where play and unity come alive! Gather, as we share and explore classes, events, retreats, and trainings.',
		link: '/community',
		image: pillar2Image.src
	},
	{
		icon: Sparkles,
		title: 'Connection',
		description: 'Find home in our healing services, where a range of offerings awaits to bring harmony and rejuvenation to both your physical and spiritual selves.',
		link: '/connection',
		image: pillar3Image.src
	}
];
---

<Layout>
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[85vh] md:min-h-screen flex items-center justify-center overflow-hidden pt-20" aria-labelledby="hero-heading">
			<div class="absolute inset-0 z-0 ">
				<!-- Fallback image -->
				<img src={heroFallbackImage.src} alt="" role="presentation" loading="eager" class="absolute inset-0 w-full h-full object-cover" />
				<!-- Vimeo video background -->
				<iframe
					src="https://player.vimeo.com/video/906709028?h=238bfbb4ec&autoplay=1&loop=1&muted=1&background=1&controls=0"
					class="absolute inset-0 w-full h-full pointer-events-none z-10"
					style="position: absolute; top: 50%; left: 50%; width: 100vw; height: 56.25vw; min-height: 100vh; min-width: 177.77vh; transform: translate(-50%, -50%);"
					frameborder="0"
					allow="autoplay; fullscreen; picture-in-picture"
					title="Hero Background Video"
				></iframe>
				<!-- Cream overlay gradient -->
				<div class="absolute inset-0 bg-gradient-to-b from-cream/05 via-cream/50 to-cream z-20"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<div
					x-data="{
						phrases: ['Love the Journey', 'Trust the Process', 'Give Gratitude', 'Receive More'],
						current: 0,
						opacity: 1,
						interval: null,
						init() {
							this.interval = setInterval(() => {
								this.opacity = 0;
								setTimeout(() => {
									this.current = (this.current + 1) % this.phrases.length;
									this.opacity = 1;
								}, 1200);
							}, 5000);
						},
						destroy() { if (this.interval) clearInterval(this.interval); }
					}"
					@destroy.window="destroy()"
				>
					<h1
						x-text="phrases[current]"
						:style="`opacity: ${opacity}; transition: opacity 1200ms ease-in-out; filter: drop-shadow(1px 2px 3px rgba(0, 0, 0, 0.3)) drop-shadow(2px 4px 6px rgba(0, 0, 0, 0.3)) drop-shadow(4px 8px 12px rgba(0, 0, 0, 0.3));`"
						id="hero-heading"
						class="text-4xl md:text-8xl font-bold tracking-wide leading-tight animated-gradient-text"
					>Love the Journey</h1>
				</div>

				<p class="text-xl md:text-2xl text-black mb-16 max-w-3xl mx-auto font-medium leading-relaxed tracking-wide">
					movement <span class="text-brand">•</span> community <span class="text-brand">•</span> connection
				</p>

				<Button href="/start" variant="primary" size="large">
					Get Started for $56
				</Button>
			</div>
		</section>

		<!-- Getting Started Section -->
		<section id="get-started" class="pt-20 pb-32 bg-cream" aria-labelledby="getting-started-heading">
			<div class="container mx-auto px-6">
				<div class="grid md:grid-cols-1 gap-6 max-w-4xl mx-auto text-center mb-16">
					<div>
						<h2 id="getting-started-heading" class="text-4xl md:text-5xl font-display font-bold text-charcoal tracking-wide mb-4">
							Getting Started Is Easy!
						</h2>
						<p class="text-lg md:text-xl text-neutral-600 font-light leading-relaxed">
							Join our community and begin your journey of self-love through mindful movement.
						</p>
					</div>
				</div>
				<div class="grid md:grid-cols-3 gap-8 md:gap-10 max-w-7xl mx-auto mb-16">
					{steps.map((step) => <StepCard {...step} />)}
				</div>
				<div class="text-center">
					<Button href="/start" variant="primary" size="large">
						3 Week Intro for $56
					</Button>
				</div>
			</div>
		</section>


		<!-- Virtual Studio Banner -->
		<section class="relative py-24 overflow-hidden" aria-labelledby="virtual-heading">
			<div class="absolute inset-0">
				<img
					src="https://images.unsplash.com/photo-1696937525057-efcb5dbc84e3?w=1600&q=80"
					alt=""
					role="presentation"
					class="w-full h-full object-cover"
				/>
				<div class="absolute inset-0 bg-neutral-900/50"></div>
				<div class="absolute inset-0 bg-gradient-to-r from-emerald-dark/30 via-emerald-dark/80 to-emerald-dark/30"></div>
			</div>
			<div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-20"></div>
			<div class="container mx-auto px-6 relative z-10">
				<div class="text-center">
					<Calendar class="w-14 h-14 text-brand mx-auto mb-6" aria-hidden="true" />
					<h2 id="virtual-heading" class="text-4xl md:text-5xl font-display font-bold text-white mb-4 tracking-wide">Join Our Virtual Studio</h2>
					<Divider width="short" class="mb-6 h-0.5" />
					<p class="text-2xl text-white/95 mb-10 max-w-2xl mx-auto font-light leading-relaxed">Premium wellness on your schedule</p>
					<Button href="/virtual" variant="primary">
						Explore Virtual Classes
					</Button>
				</div>
			</div>
		</section>

		<!-- About Section -->
		<section class="py-24 bg-cream-100" aria-labelledby="about-heading">
			<div class="container mx-auto px-6">
				<div class="grid md:grid-cols-2 gap-20 items-center max-w-6xl mx-auto">
					<div>
						<img src={aboutImage.src} alt="Yoga studio atmosphere" loading="lazy" class="rounded-2xl shadow-md border border-warm-gray-200" />
					</div>

					<div>
						<h2 id="about-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">Who is Love More?</h2>
						<!--<Divider width="short" class="mb-8" />-->
						<p class="text-lg text-neutral-600 mb-6 leading-relaxed">
							We're a warm-hearted community here to lead you on a self-love journey through movement, community, and connection. Through our classes, events, trainings, retreats, and healing services, our mission is to embrace the art of learning to LOVE MORE.
						</p>
						<p class="text-lg text-neutral-600 mb-6 leading-relaxed">
							So welcome to the Love More family! It’s about finding your people, rooting into your authentic self, and exploring your potential. We’re here to support you every step of the way!
						</p>
						<Button href="/about" variant="primary">
							Discover Our Story
						</Button>
					</div>
				</div>
			</div>
		</section>

		<!-- Core Pillars Section -->
		<section class="py-24 bg-white" aria-labelledby="pillars-heading">
			<div class="container mx-auto px-6">
				<div class="text-center mb-16">
					<p class="text-neutral-500 text-sm font-medium tracking-luxury-wide uppercase">Our Foundation</p>
					<h2 id="pillars-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mt-2 mb-6 tracking-wide">Three Pillars</h2>
					<Divider width="long" />
				</div>
				<div class="grid md:grid-cols-3 gap-8">
					{pillars.map((pillar) => <PillarCard {...pillar} />)}
				</div>
			</div>
		</section>

		<!-- Meet Our Teachers Section -->
		<section class="py-32 bg-cream" aria-labelledby="teachers-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center mb-16">
					<h2 id="teachers-heading" class="text-4xl md:text-5xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Meet Our Teachers
					</h2>
					<p class="text-lg text-neutral-600 leading-relaxed">
						Warm, uplifting and embodied wellness experts dedicated to guiding you on your journey. Our teachers are selected for their ability to inspire, educate and support your wellbeing goals.
					</p>
				</div>

				<div class="grid md:grid-cols-3 gap-x-6 gap-y-16 max-w-5xl mx-auto mb-12">
					{teamMembers.map((member, index) => (
						<TeamMemberCard
							name={member.name}
							title={member.title}
							image={member.image}
							index={index}
						/>
					))}
				</div>

				<div class="text-center">
					<a
						href="/team"
						class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-6 py-3 text-sm"
					>
						Get Know Our Team
					</a>
				</div>
			</div>
		</section>

		<!-- Email Signup Section -->
		<section class="py-24 bg-cream-50" aria-labelledby="newsletter-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto">
					<div class="bg-white p-12 rounded-2xl shadow-md border border-warm-gray-200">
						<div class="text-center mb-10">
							<Mail class="w-12 h-12 text-brand mx-auto mb-6" aria-hidden="true" />
							<h2 id="newsletter-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">Let's Stay Connected</h2>
							<p class="text-lg text-neutral-600">Join our community for exclusive updates, curated events, and inspiration.</p>
						</div>

						<!-- START TEMPLATE -->
						<!--<script type="module" src="https://widgets.wellnessliving.com/lead-capture/widget.js"></script>-->
						<!--<wl-lead-capture-widget k_business="288067" k_skin="271461" k_location=""></wl-lead-capture-widget>-->
						<!-- END TEMPLATE -->

						<!-- BEGIN WELLNESSLIVING CODE -->
						<div class="wl-widget" data="k_skin=271461&amp;k_business=288067"></div><!-- html check -->
						<script src="https://www.wellnessliving.com/rs/skin-widget-static.js" type="text/javascript"></script>

						<br clear="both" />
						<!-- html check -->
						<!-- END WELLNESSLIVING CODE -->
						<!-- html check -->

						<!--<form name="newsletter" method="POST" action="/thank-you" data-netlify="true" netlify-honeypot="bot-field" class="space-y-6">-->
						<!--	<input type="hidden" name="form-name" value="newsletter" />-->
						<!--	<p class="hidden" aria-hidden="true"><label>Don't fill this out if you're human: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>-->
						<!--	<div>-->
						<!--		<label for="email" class="sr-only">Email address</label>-->
						<!--		<input type="email" id="email" name="email" placeholder="Your email address" required aria-required="true" class="w-full px-8 py-5 rounded-lg border border-warm-gray-200 focus:border-brand focus:ring-4 focus:ring-brand/20 outline-none transition-all text-lg" />-->
						<!--	</div>-->
						<!--	<Button type="submit" class="w-full">-->
						<!--		Join Our Community-->
						<!--	</Button>-->
						<!--</form>-->

						<p class="text-sm text-neutral-500 text-center mt-8">We respect your privacy. We will never share your email or spam you.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Team Member Modal -->
		<TeamMemberModal />
	</main>

	<Footer />
</Layout>

<script define:vars={{ teamMembers }}>
	// Store team members data in JavaScript
	const members = teamMembers;

	// Add click handlers after DOM loads
	document.addEventListener('alpine:init', () => {
		// Wait for Alpine to be ready
		setTimeout(() => {
			const cards = document.querySelectorAll('[data-member-index]');
			cards.forEach((card) => {
				card.addEventListener('click', () => {
					const index = parseInt(card.getAttribute('data-member-index'));
					const member = members[index];
					// Dispatch custom event with member data
					window.dispatchEvent(new CustomEvent('modal-open', { detail: member }));
				});
			});
		}, 100);
	});
</script>
