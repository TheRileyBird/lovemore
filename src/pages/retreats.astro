---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Divider from '../components/Divider.astro';
import { Palmtree, Calendar, ArrowRight } from 'lucide-astro';
import { fetchAPI, getStrapiMedia } from '../lib/strapi';
import { marked } from 'marked';

// Helper to handle both HTML and Markdown content
function processContent(content: string): string {
	if (!content) return '';
	// If content contains HTML tags, return as-is
	if (content.includes('<p>') || content.includes('<strong>')) {
		return content;
	}
	// Otherwise treat as Markdown
	return marked(content);
}

// Helper to strip HTML tags for plain text display
function stripHtml(html: string): string {
	if (!html) return '';
	return html.replace(/<[^>]*>/g, '').replace(/&[^;]+;/g, (entity) => {
		const entities: Record<string, string> = {
			'&amp;': '&',
			'&lt;': '<',
			'&gt;': '>',
			'&quot;': '"',
			'&#39;': "'"
		};
		return entities[entity] || entity;
	});
}

// Fetch retreats from Strapi
const retreatsResponse = await fetchAPI<any>({
	endpoint: 'retreats',
	query: {
		sort: 'sortOrder:asc',
		'filters[active][$eq]': true,
		'populate': 'image'
	},
	wrappedByKey: 'data'
});

// Filter for upcoming retreats only (not past events)
const now = new Date();
const upcomingRetreats = retreatsResponse
	?.filter((retreat: any) => {
		// Must have a slug
		if (!retreat.slug) return false;
		// If no endDate, show it (assume upcoming)
		if (!retreat.endDate) return true;
		// Only show if endDate is in the future
		return new Date(retreat.endDate) >= now;
	})
	.map((retreat: any) => ({
		name: retreat.name,
		subtitle: retreat.subtitle,
		slug: retreat.slug,
		location: retreat.location,
		image: retreat.image?.url ? getStrapiMedia(retreat.image.url) : null,
		body: stripHtml(retreat.body),
		startDate: retreat.startDate,
		endDate: retreat.endDate
	})) || [];
---

<Layout title="Retreats - Elevate — Love More">
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden" aria-labelledby="retreats-heading">
			<div class="absolute inset-0 z-0">
				<img
					src="https://images.squarespace-cdn.com/content/v1/59d53a9459cc683b30818a39/1698857393487-I0M9VNSSDU0WURO47UYG/IMG_5194.jpeg?format=1600w"
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
					style="object-position: 100% 40%;"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<Palmtree class="w-16 h-16 text-brand mx-auto mb-6" aria-hidden="true" />
				<h1 id="retreats-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide mb-4">
					Retreats
				</h1>
				<p class="text-2xl text-white/95 max-w-2xl mx-auto font-light">
					Elevate Your Practice in Paradise
				</p>
			</div>
		</section>

		<!-- Intro Section -->
		<section class="py-20 bg-cream" aria-labelledby="intro-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-4xl mx-auto text-center">
					<h2 id="intro-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
						Journey Beyond the Studio
					</h2>
					<Divider width="short" class="mb-8" />
					<p class="text-lg text-neutral-600 leading-relaxed mb-6">
						Escape the everyday and immerse yourself in transformative yoga retreats in some of the world's most beautiful destinations. Our carefully curated retreats offer the perfect blend of practice, adventure, relaxation, and community.
					</p>
					<p class="text-lg text-neutral-600 leading-relaxed">
						Whether you're seeking spiritual renewal in the red rocks of Sedona or tropical bliss in Costa Rica, our retreats provide space to deepen your practice, connect with like-minded souls, and return home renewed.
					</p>
				</div>
			</div>
		</section>

		<!-- Upcoming Retreats -->
		<section class="py-24 bg-white" aria-labelledby="upcoming-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<h2 id="upcoming-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-12 text-center tracking-wide">
						Upcoming Retreats
					</h2>

					<div class="flex flex-col gap-y-8">
						{upcomingRetreats.map((retreat, index) => {
							// Format dates for display
							const formatDate = (date: string) => {
								return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
							};
							const dateDisplay = retreat.startDate && retreat.endDate
								? `${formatDate(retreat.startDate)} - ${formatDate(retreat.endDate)}`
								: retreat.startDate
									? formatDate(retreat.startDate)
									: retreat.endDate
										? formatDate(retreat.endDate)
										: '';

							return (
								<a
									href={`/retreats/${retreat.slug}`}
									class={`group grid grid-cols-1 overflow-clip rounded-[1.875rem] border border-neutral-200 bg-cream lg:grid-cols-2 lg:grid-rows-1 transition-all duration-500 hover:shadow-2xl ${index % 2 === 1 ? 'lg:grid-flow-dense' : ''}`}
								>
									<div class={`relative ${index % 2 === 1 ? 'lg:col-start-2' : ''}`}>
										<header class="flex flex-nowrap items-center justify-between gap-x-4 border-b border-neutral-200 px-8 py-6">
											<h3 class="text-xl font-bold text-charcoal">
												{retreat.name}
											</h3>
											<span class="inline-flex items-center gap-1 px-3 py-1 bg-cream rounded-full border border-neutral-200 text-sm shrink-0">
												<Calendar class="w-4 h-4 text-brand" aria-hidden="true" />
												{dateDisplay || 'TBD'}
											</span>
										</header>
										<div class="p-10 pb-20">
											{retreat.subtitle && (
												<p class="text-lg text-neutral-600 font-medium mb-3">{retreat.subtitle}</p>
											)}
											<div class="prose line-clamp-6 max-w-none text-neutral-600 leading-relaxed [&_p]:mb-4">{retreat.body}</div>
										</div>
										<div class="absolute bottom-0 left-0 right-0 px-10 pb-6 translate-y-0 opacity-100 lg:translate-y-full lg:opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
											<span class="inline-flex items-center gap-2 py-3 text-brand font-bold tracking-wider uppercase text-sm">
												Learn More
												<ArrowRight class="w-4 h-4" aria-hidden="true" />
											</span>
										</div>
									</div>
									<div class={`relative select-none bg-neutral-50 h-full min-h-[300px] overflow-hidden ${index % 2 === 1 ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
										<img
											src={retreat.image || 'https://images.unsplash.com/photo-1537953773345-d172ccf13cf1?w=1200&auto=format&fit=crop&q=80'}
											alt={retreat.name}
											class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-110"
										/>
									</div>
								</a>
							);
						})}
					</div>
				</div>
			</div>
		</section>

		<!-- Call to Action -->
		<section class="py-20 bg-cream">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Ready for Your Next Adventure?
					</h2>
					<p class="text-lg text-neutral-600 mb-8 leading-relaxed">
						Spaces are limited and fill quickly. Contact us today to learn more about our upcoming retreats, pricing, and availability.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<Button href="/contact" variant="primary" size="large">
							Get in Touch
						</Button>
						<a
							href="/events"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
						>
							View All Events
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
