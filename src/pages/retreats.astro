---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Divider from '../components/Divider.astro';
import { Palmtree } from 'lucide-astro';
import { fetchAPI, getStrapiMedia } from '../lib/strapi';

// Fetch retreats from Strapi
const retreatsResponse = await fetchAPI<any>({
	endpoint: 'retreats',
	query: {
		sort: 'order:asc',
		'filters[active][$eq]': true,
		'populate': 'image'
	},
	wrappedByKey: 'data'
});

const upcomingRetreats = retreatsResponse?.map((retreat: any) => ({
	name: retreat.name,
	slug: retreat.slug,
	location: retreat.location,
	image: retreat.image?.url ? getStrapiMedia(retreat.image.url) : null,
	body: retreat.body
})) || [];
---

<Layout title="Retreats - Elevate — Love More">
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="retreats-heading">
			<div class="absolute inset-0 z-0">
				<img
					src="https://images.squarespace-cdn.com/content/v1/59d53a9459cc683b30818a39/1698857393487-I0M9VNSSDU0WURO47UYG/IMG_5194.jpeg?format=1600w"
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
					style="object-position: 100% 40%;"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<Palmtree class="w-16 h-16 text-brand mx-auto mb-6" aria-hidden="true" />
				<h1 id="retreats-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide mb-4">
					Retreats
				</h1>
				<p class="text-2xl text-white/95 max-w-2xl mx-auto font-light">
					Elevate Your Practice in Paradise
				</p>
			</div>
		</section>

		<!-- Intro Section -->
		<section class="py-20 bg-cream" aria-labelledby="intro-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-4xl mx-auto text-center">
					<h2 id="intro-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
						Journey Beyond the Studio
					</h2>
					<Divider width="short" class="mb-8" />
					<p class="text-lg text-neutral-600 leading-relaxed mb-6">
						Escape the everyday and immerse yourself in transformative yoga retreats in some of the world's most beautiful destinations. Our carefully curated retreats offer the perfect blend of practice, adventure, relaxation, and community.
					</p>
					<p class="text-lg text-neutral-600 leading-relaxed">
						Whether you're seeking spiritual renewal in the red rocks of Sedona or tropical bliss in Costa Rica, our retreats provide space to deepen your practice, connect with like-minded souls, and return home renewed.
					</p>
				</div>
			</div>
		</section>

		<!-- Upcoming Retreats -->
		<section class="py-24 bg-white" aria-labelledby="upcoming-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<h2 id="upcoming-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-12 text-center tracking-wide">
						Upcoming Retreats
					</h2>

					<div class="space-y-12">
						{upcomingRetreats.map((retreat) => {
							// Extract plain text from body for preview
							const plainText = retreat.body?.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim() || '';
							const preview = plainText.length > 250 ? plainText.substring(0, 250) + '...' : plainText;

							return (
								<div class="bg-cream-50 rounded-3xl overflow-hidden shadow-lg border border-warm-gray-200 hover:shadow-xl transition-shadow">
									<div class="grid md:grid-cols-5 gap-0">
										<div class="md:col-span-2 relative h-64 md:h-auto">
											<img
												src={retreat.image || 'https://images.unsplash.com/photo-1537953773345-d172ccf13cf1?w=1200&auto=format&fit=crop&q=80'}
												alt={retreat.name}
												class="absolute inset-0 w-full h-full object-cover"
											/>
											<div class="absolute inset-0 bg-neutral-900/40"></div>
											<div class="absolute inset-0 flex items-center justify-center">
												<div class="text-center text-white p-8">
													<Palmtree class="w-16 h-16 mx-auto mb-4" aria-hidden="true" />
													<h3 class="text-3xl font-display font-bold mb-2">{retreat.name}</h3>
													<p class="text-xl opacity-90">{retreat.location}</p>
												</div>
											</div>
										</div>

										<div class="md:col-span-3 p-8 md:p-10">
											<p class="text-lg text-neutral-600 leading-relaxed mb-8">
												{preview}
											</p>

											<Button href={`/retreats/${retreat.slug}`} variant="primary">
												Learn More
											</Button>
										</div>
									</div>
								</div>
							);
						})}
					</div>
				</div>
			</div>
		</section>

		<!-- Call to Action -->
		<section class="py-20 bg-cream">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Ready for Your Next Adventure?
					</h2>
					<p class="text-lg text-neutral-600 mb-8 leading-relaxed">
						Spaces are limited and fill quickly. Contact us today to learn more about our upcoming retreats, pricing, and availability.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<Button href="/contact" variant="primary" size="large">
							Get in Touch
						</Button>
						<a
							href="/events"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
						>
							View All Events
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
