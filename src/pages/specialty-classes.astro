---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Divider from '../components/Divider.astro';
import { Sparkles } from 'lucide-astro';
import { fetchAPI, getStrapiMedia } from '../lib/strapi';

// Fetch specialty classes from Strapi
const specialtyClassesResponse = await fetchAPI<any>({
	endpoint: 'classes',
	query: {
		'filters[type][$eq]': 'specialty',
		'populate': 'image',
		'sort': 'order:asc'
	},
	wrappedByKey: 'data'
});

const specialtyOfferings = specialtyClassesResponse.map((classItem: any) => ({
	name: classItem.name,
	description: classItem.description,
	image: classItem.image?.url ? getStrapiMedia(classItem.image.url) : null
}));
---

<Layout title="Specialty Classes — Love More">
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="specialty-heading">
			<div class="absolute inset-0 z-0">
				<img
					src="https://images.squarespace-cdn.com/content/v1/59d53a9459cc683b30818a39/1698857393487-I0M9VNSSDU0WURO47UYG/IMG_5194.jpeg?format=1600w"
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
					style="object-position: 100% 40%;"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<Sparkles class="w-16 h-16 text-brand mx-auto mb-6" aria-hidden="true" />
				<h1 id="specialty-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide">
					Specialty Classes
				</h1>
			</div>
		</section>

		<!-- Intro Section -->
		<section class="py-16 bg-cream" aria-labelledby="intro-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 id="intro-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
						Explore Beyond the Mat
					</h2>
					<Divider width="short" class="mb-6" />
					<p class="text-lg text-neutral-600 leading-relaxed">
						Expand your practice with our unique specialty offerings. From aerial yoga to sound healing, these special classes and workshops provide opportunities to deepen your connection and explore new dimensions of wellness.
					</p>
				</div>
			</div>
		</section>

		<!-- Specialty Offerings -->
		<section class="py-24 bg-white" aria-labelledby="offerings-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<h2 id="offerings-heading" class="text-4xl md:text-5xl font-display font-bold text-charcoal mb-4 tracking-wide text-center">
						Special Offerings
					</h2>
					<p class="text-center text-lg text-neutral-600 mb-16 max-w-3xl mx-auto">
						Unique experiences designed to deepen your practice, expand your skills, and connect with our community in meaningful ways.
					</p>

					<div class="flex flex-col gap-y-8">
						{specialtyOfferings.map((offering, index) => (
							<div class={`grid grid-cols-1 overflow-clip rounded-[1.875rem] border border-neutral-200 bg-cream lg:grid-cols-2 lg:grid-rows-1 ${index % 2 === 1 ? 'lg:grid-flow-dense' : ''}`}>
								<div class={`${index % 2 === 1 ? 'lg:col-start-2' : ''}`}>
									<header class="flex items-center justify-between gap-x-4 border-b border-neutral-200 px-8 py-6">
										<h3 class="text-xl font-bold text-charcoal">
											{offering.name}
										</h3>
										<span class="inline-flex items-center gap-1 px-3 py-1 bg-white rounded-full border border-neutral-200 text-sm shrink-0">
											<Sparkles class="w-4 h-4 text-purple-500" aria-hidden="true" />
											Special
										</span>
									</header>
									<div class="flex flex-col place-items-start gap-y-6 p-10">
										<p class="text-neutral-600 leading-relaxed">
											{offering.description}
										</p>
									</div>
								</div>
								<div class={`relative select-none bg-neutral-50 h-full ${index % 2 === 1 ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
									{offering.image ? (
										<img
											src={offering.image}
											alt=""
											class="absolute inset-0 w-full h-full object-cover"
										/>
									) : (
										<div class="absolute inset-0 w-full h-full flex items-center justify-center bg-gradient-to-br from-purple-100 to-purple-50">
											<Sparkles class="w-24 h-24 text-purple-300" aria-hidden="true" />
										</div>
									)}
								</div>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Call to Action -->
		<section class="py-20 bg-cream">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Ready to Explore?
					</h2>
					<p class="text-lg text-neutral-600 mb-8 leading-relaxed">
						Check our events calendar for upcoming specialty classes and workshops, or reach out to learn more about our offerings.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<Button href="/events" variant="primary" size="large">
							View Events
						</Button>
						<a
							href="/contact"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
						>
							Contact Us
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
