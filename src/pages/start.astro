---
import '../styles/global.css';
import logoImage from '../assets/images/logo.webp';
import { Heart, Clock, TrendingUp, Users, Sparkles } from 'lucide-astro';

const benefits = [
	{
		icon: Sparkles,
		title: 'Start Strong',
		description: 'Begin with intention and build a solid foundation for your practice'
	},
	{
		icon: Clock,
		title: 'Consistency is Key',
		description: 'Develop a sustainable routine that fits your lifestyle'
	},
	{
		icon: TrendingUp,
		title: 'Track Your Progress',
		description: 'See real results and transformation by class 9'
	},
	{
		icon: Heart,
		title: 'Feel the Love',
		description: 'Connect with our supportive community of like-minded souls'
	},
	{
		icon: Users,
		title: 'Expert Guidance',
		description: 'Learn from experienced instructors who care about your journey'
	},
	{
		icon: Sparkles,
		title: 'Unlimited Classes',
		description: 'Attend as many classes as you want during your 21-day pass'
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Start your Love More journey with our 3-week intro pass for just $56. No hidden renewals, just 21 days of transformative yoga and movement." />
		<title>Get Started for $56 | Love More</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
	</head>
	<body class="bg-cream font-body text-charcoal antialiased">
		<!-- Hero Section -->
		<section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
			<div class="absolute inset-0">
				<img
					src="https://images.unsplash.com/photo-1588286840104-8957b019727f?w=1600&q=80"
					alt=""
					class="w-full h-full object-cover"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/70"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<!-- Logo -->
				<div class="mb-12">
					<img
						src={logoImage.src}
						alt="Love More"
						class="w-auto h-16 mx-auto"
					/>
				</div>

				<h1 class="text-5xl md:text-7xl font-display font-light text-white mb-6 tracking-wide">
					Get Started
				</h1>
				<p class="text-2xl md:text-3xl text-white/95 mb-8 font-light">
					3 Week Intro Pass — <span class="text-gold font-medium">$56</span>
				</p>
				<p class="text-lg md:text-xl text-white/90 max-w-2xl mx-auto font-light leading-relaxed">
					Activates on your first visit. No hidden renewals—just 21 days of pure movement, connection, and transformation.
				</p>
			</div>
		</section>

		<!-- Benefits Section -->
		<section class="py-24 bg-white">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<div class="text-center mb-16">
						<h2 class="text-4xl md:text-5xl font-display font-light text-charcoal mb-6 tracking-wide">
							Your Journey Starts Here
						</h2>
						<p class="text-lg text-neutral-600 max-w-3xl mx-auto font-light leading-relaxed">
							Our 3-week intro pass is designed to help you build consistency, see real results, and feel at home in our community.
						</p>
					</div>

					<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
						{benefits.map((benefit) => (
							<div class="bg-cream-50 border rounded-2xl p-8 hover:shadow-lg transition-shadow duration-300 border border-neutral-900">
								<div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
									<benefit.icon class="w-6 h-6 text-brand" />
								</div>
								<h3 class="text-xl font-display font-medium text-charcoal mb-3">
									{benefit.title}
								</h3>
								<p class="text-base text-neutral-600 leading-relaxed">
									{benefit.description}
								</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Booking Section -->
		<section class="py-24 bg-cream" id="book">
			<div class="container mx-auto px-6">
				<div class="max-w-4xl mx-auto">
					<div class="text-center mb-12">
						<h2 class="text-4xl md:text-5xl font-display font-light text-charcoal mb-6 tracking-wide">
							Book Your First Class
						</h2>
						<p class="text-lg text-neutral-600 font-light leading-relaxed">
							Choose a class time that works for you and activate your 3-week intro pass.
						</p>
					</div>

					<!-- Embed Code Placeholder -->
					<div class="bg-white rounded-2xl shadow-lg p-8 min-h-[500px] flex items-center justify-center">
						<div class="text-center">
							<p class="text-neutral-400 text-sm uppercase tracking-wider mb-2">
								WellnessLiving Embed
							</p>
							<p class="text-neutral-600">
								Insert booking widget embed code here
							</p>
						</div>
						<!-- Replace this div with your WellnessLiving embed code -->
					</div>
				</div>
			</div>
		</section>

		<!-- Final CTA -->
		<section class="py-16 bg-brand">
			<div class="container mx-auto px-6 text-center">
				<h3 class="text-3xl md:text-4xl font-display font-light text-white mb-4 tracking-wide">
					Ready to Begin?
				</h3>
				<p class="text-lg text-white/90 mb-8 font-light">
					Scroll up to book your first class and activate your $56 intro pass.
				</p>
				<a
					href="#book"
					class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 bg-white text-brand hover:bg-cream-50 shadow-lg hover:shadow-xl px-8 py-4 text-sm"
				>
					Book Now
				</a>
			</div>
		</section>

		<!-- Simple Footer -->
		<footer class="py-8 bg-charcoal text-center">
			<p class="text-white/60 text-sm">
				© {new Date().getFullYear()} Love More. Movement • Community • Connection
			</p>
		</footer>
	</body>
</html>
