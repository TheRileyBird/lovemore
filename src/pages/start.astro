---
import '../styles/global.css';
import logoImage from '../assets/images/icon.webp';
import { Heart, Clock, TrendingUp, Users, Sparkles } from 'lucide-astro';

const benefits = [
	{
		icon: Sparkles,
		title: 'Start Strong',
		description: 'Begin with intention and build a solid foundation for your practice'
	},
	{
		icon: Clock,
		title: 'Consistency is Key',
		description: 'Develop a sustainable routine that fits your lifestyle'
	},
	{
		icon: TrendingUp,
		title: 'Track Your Progress',
		description: 'See real results and transformation by class 9'
	},
	{
		icon: Heart,
		title: 'Feel the Love',
		description: 'Connect with our supportive community of like-minded souls'
	},
	{
		icon: Users,
		title: 'Expert Guidance',
		description: 'Learn from experienced instructors who care about your journey'
	},
	{
		icon: Sparkles,
		title: 'Unlimited Classes',
		description: 'Attend as many classes as you want during your 21-day pass'
	}
];

const testimonials = [
	{
		text: 'Love More has completely transformed my relationship with movement. The community is so warm and welcoming, and I feel stronger both physically and mentally.',
		name: 'Sarah M.'
	},
	{
		text: 'I was nervous to start, but the 3-week intro was perfect. By week two I was hooked! The instructors are amazing and really help you find your practice.',
		name: 'Jessica L.'
	},
	{
		text: 'This studio feels like home. The energy, the people, the classes—everything about Love More just makes sense. Best decision I\'ve made for myself.',
		name: 'Emily R.'
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Start your Love More journey with our 3-week intro pass for just $56. No hidden renewals, just 21 days of transformative yoga and movement." />
		<title>Get Started for $56 | Love More</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Love More" />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />

		<!-- Favicons -->
		<link rel="icon" type="image/svg+xml" href="/favicon.png" />
		<!--<link rel="icon" href="/favicon.ico" />-->
		<!--<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />-->

		<!-- Luxury Fonts - Optimized with font-display swap -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Cormorant+Garamond:wght@300;400;500;600;700&family=Gilda+Display&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="bg-cream font-body text-charcoal antialiased">
		<!-- Hero Section -->
		<section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden">
			<div class="absolute inset-0">
				<img
					src="https://images.unsplash.com/photo-1588286840104-8957b019727f?w=1600&q=80"
					alt=""
					class="w-full h-full object-cover"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/70"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<h1 class="text-5xl uppercase md:text-7xl font-display font-light text-white mb-6 tracking-wide">
					Get Started
				</h1>
				<p class="text-2xl md:text-3xl text-white/95 font-bold">
					3 Week Intro Pass — $56
				</p>
			</div>
		</section>

		<!-- Benefits Section -->
		<section class="py-24 bg-white">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<div class="text-center mb-16">
						<h2 class="text-4xl md:text-5xl font-display font-light text-charcoal mb-6 tracking-wide">
							Your Journey Starts Here
						</h2>
						<p class="text-lg text-neutral-600 max-w-3xl mx-auto font-light leading-relaxed">
							Our 3-week intro pass is designed to help you build consistency, see real results, and feel at home in our community.
						</p>
					</div>

					<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
						{benefits.map((benefit) => (
							<div class="bg-cream-50 border rounded-2xl p-8 hover:shadow-lg transition-shadow duration-300 border border-neutral-900">
								<div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
									<benefit.icon class="w-6 h-6 text-brand" />
								</div>
								<h3 class="text-xl font-display font-medium text-charcoal mb-3">
									{benefit.title}
								</h3>
								<p class="text-base text-neutral-600 leading-relaxed">
									{benefit.description}
								</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Booking Section -->
		<section class="py-24 bg-cream" id="book">
			<div class="container mx-auto px-6">
				<div class="max-w-4xl mx-auto">
					<div class="text-center">
						<!-- Logo -->
						<div class="mb-8">
							<img
								src={logoImage.src}
								alt="Love More"
								class="w-auto h-24 mx-auto"
							/>
						</div>
						<h2 class="text-4xl md:text-5xl font-display font-light text-charcoal mb-6 tracking-wide">
							Begin Your Transformation
						</h2>
						<p class="text-2xl md:text-3xl text-brand font-bold mb-4 tracking-wide">
							GET STARTED FOR $56!
						</p>
						<p class="text-lg text-neutral-600 font-light leading-relaxed mb-8">
							Activates on your first visit. No hidden renewals—just 21 days of pure yoga.
						</p>
						<a
							href="#book"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 bg-brand text-white hover:bg-brand-dark shadow-sm hover:shadow-md hover:translate-y-[-1px] px-8 py-4 text-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
						>
							Claim Your Intro Pass
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Testimonials Section -->
		<section class="py-24 bg-white">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<div class="text-center mb-16">
						<p class="text-brand-dark text-sm font-medium tracking-wider uppercase mb-3">Love Letters</p>
						<h2 class="text-4xl md:text-5xl font-display font-light text-charcoal tracking-wide">
							From the Mat
						</h2>
					</div>
					<!-- BEGIN WELLNESSLIVING CODE -->
					<div class="wl-widget" data="k_skin=199160&amp;k_business=288067"></div><!-- html check -->
					<script src="https://www.wellnessliving.com/rs/skin-widget-static.js" type="text/javascript"></script>
					<br clear="both" />
					<!-- html check -->
					<!-- END WELLNESSLIVING CODE -->
				</div>
			</div>
		</section>

		<!-- Final CTA -->
		<section class="py-16 bg-brand">
			<div class="container mx-auto px-6 text-center">
				<h3 class="text-3xl md:text-4xl font-display font-light text-white mb-4 tracking-wide">
					Ready to Begin?
				</h3>
				<p class="text-lg text-white/90 mb-8 font-light">
					Scroll up to book your first class and activate your $56 intro pass.
				</p>
				<a
					href="#book"
					class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 bg-white text-brand hover:bg-cream-50 shadow-lg hover:shadow-xl px-8 py-4 text-sm"
				>
					Book Now
				</a>
			</div>
		</section>

		<!-- Simple Footer -->
		<footer class="py-8 bg-charcoal text-center">
			<p class="text-white/60 text-sm">
				© {new Date().getFullYear()} Love More • Movement • Community • Connection
			</p>
		</footer>
	</body>
</html>
