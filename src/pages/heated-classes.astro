---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Divider from '../components/Divider.astro';
import { Flame } from 'lucide-astro';

const classes = [
	{
		name: 'Hot 26+2',
		temperature: '105°F',
		level: 'All Levels',
		description: 'The original hot yoga sequence of 26 postures and 2 breathing exercises practiced in a heated room.'
	},
	{
		name: 'Warm Vinyasa',
		temperature: '90-95°F',
		level: 'All Levels',
		description: 'Dynamic flowing sequences linking breath to movement in a comfortably heated space.'
	},
	{
		name: 'Hot Power Flow',
		temperature: '100-105°F',
		level: 'Intermediate to Advanced',
		description: 'Athletic and challenging vinyasa-style practice building strength and endurance.'
	},
	{
		name: 'Hot Yin',
		temperature: '95-100°F',
		level: 'All Levels',
		description: 'Passive, floor-based practice with longer holds to target deep connective tissues.'
	},
	{
		name: 'Heated Sculpt',
		temperature: '90-95°F',
		level: 'All Levels',
		description: 'Yoga-inspired strength training combining bodyweight exercises, light weights, and cardio bursts.'
	}
];
---

<Layout title="Heated Classes — Love More">
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="heated-heading">
			<div class="absolute inset-0 z-0">
				<img
					src="https://images.squarespace-cdn.com/content/v1/59d53a9459cc683b30818a39/1698857393487-I0M9VNSSDU0WURO47UYG/IMG_5194.jpeg?format=1600w"
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
					style="object-position: 100% 40%;"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<Flame class="w-16 h-16 text-brand mx-auto mb-6" aria-hidden="true" />
				<h1 id="heated-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide">
					Heated Classes
				</h1>
			</div>
		</section>

		<!-- Intro Section -->
		<section class="py-16 bg-cream" aria-labelledby="intro-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 id="intro-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
						Transform with Heat
					</h2>
					<Divider width="short" class="mb-6" />
					<p class="text-lg text-neutral-600 leading-relaxed">
						Experience the detoxifying and transformative benefits of practicing in our heated studios. From the original hot yoga sequence to dynamic power flows, our heated classes offer something for every practitioner.
					</p>
				</div>
			</div>
		</section>

		<!-- Class Listings -->
		<section class="py-24 bg-white" aria-labelledby="classes-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-5xl mx-auto">
					<h2 id="classes-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-12 text-center tracking-wide">
						Our Heated Class Offerings
					</h2>

					<div class="space-y-6">
						{classes.map((classItem) => (
							<div class="bg-cream-50 rounded-2xl p-8 shadow-sm border border-warm-gray-200">
								<div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
									<div>
										<h3 class="text-2xl font-display font-bold text-charcoal mb-2">{classItem.name}</h3>
										<div class="flex flex-wrap gap-3 text-sm">
											<span class="inline-flex items-center gap-1 px-3 py-1 bg-white rounded-full border border-warm-gray-200">
												<Flame class="w-4 h-4 text-brand" aria-hidden="true" />
												{classItem.temperature}
											</span>
											<span class="px-3 py-1 bg-white rounded-full border border-warm-gray-200">
												{classItem.level}
											</span>
										</div>
									</div>
								</div>
								<p class="text-neutral-600 leading-relaxed">
									{classItem.description}
								</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Call to Action -->
		<section class="py-20 bg-cream">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6 tracking-wide">
						Ready to Feel the Heat?
					</h2>
					<p class="text-lg text-neutral-600 mb-8 leading-relaxed">
						Check our schedule to find the perfect heated class for you, or start with our intro offer.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<Button href="/schedule" variant="primary" size="large">
							View Schedule
						</Button>
						<a
							href="/start"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
						>
							3 Week Intro — $56
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
