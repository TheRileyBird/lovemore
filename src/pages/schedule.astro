---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import { Calendar } from 'lucide-astro';
import heroImage from '../assets/images/class.jpg';
---

<Layout title="Schedule — Love More">
	<Navigation />

	<main id="main-content">
		<!-- Hero Section -->
		<section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden pt-20" aria-labelledby="schedule-heading">
			<div class="absolute inset-0 z-0">
				<img
					src={heroImage.src}
					alt=""
					role="presentation"
					class="absolute inset-0 w-full h-full object-cover"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-neutral-900/60 via-neutral-900/50 to-neutral-900/60"></div>
			</div>

			<div class="relative z-10 container mx-auto px-6 text-center">
				<Calendar class="w-14 h-14 text-brand mx-auto mb-6 opacity-90" aria-hidden="true" />
				<h1 id="schedule-heading" class="text-5xl md:text-7xl font-display font-bold text-white tracking-wide">
					Schedule
				</h1>
			</div>
		</section>

		<!-- Schedule Widget Section -->
		<section class="pb-16 bg-white" aria-labelledby="booking-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-6xl mx-auto">
					<h2 id="booking-heading" class="sr-only">Book Your Class</h2>

					<!-- BEGIN WELLNESSLIVING CODE -->
					<div class="wl-widget" data="k_skin=201419&amp;k_business=288067"></div><!-- html check -->
					<script src="https://www.wellnessliving.com/rs/skin-widget-static.js" type="text/javascript"></script>

					<br clear="both" />
					<!-- html check -->
					<!-- END WELLNESSLIVING CODE -->
				</div>
			</div>
		</section>


		<!-- Intro Section -->
		<section class="py-12 bg-cream" aria-labelledby="intro-heading">
			<div class="container mx-auto px-6">
				<div class="max-w-3xl mx-auto text-center">
					<h2 id="intro-heading" class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4 tracking-wide">
						We'll save a place just for you
					</h2>
					<p class="text-lg text-neutral-600 mb-8">
						Can't make it into the studio? Check out our virtual studio with the button below!
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<Button href="/start" variant="primary" size="large">
							Virtual Studio
						</Button>
						<a
							href="/start"
							class="inline-flex items-center justify-center gap-2 font-medium tracking-wider uppercase rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2 bg-transparent border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white px-8 py-4 text-base"
						>
							NEW TO YOGA?
						</a>
					</div>
				</div>
			</div>
		</section>

	</main>

	<Footer />
</Layout>

<script>
	// Load WellnessLiving widget script
	const script = document.createElement('script');
	script.src = 'https://www.wellnessliving.com/rs/skin-widget-static.js';
	script.async = true;
	document.body.appendChild(script);
</script>
